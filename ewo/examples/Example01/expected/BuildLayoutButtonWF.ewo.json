{
  "id": "BuildLayoutButtonWF",
  "version": "1.0.0",
  "name": "BuildLayoutButtonWF",
  "description": "レイアウトボタンを構築する。SearchLineAC→FirstRowAC→DeployBlockWF→ボタンアンカー取得→AnchorKey/Label/JointId取得(1回)→SearchLayoutJsonACでblockKeys取得→ForEach blockKey[RemoveEndBracketsAC→BuildLayoutBlockKeyWF→CreateLayoutBlockPropertyAC→BuildLayoutBlockRowAC]→結果収集。",
  "inputs": {
    "layoutRows": { "schema": "any[]" },
    "isRoot": { "schema": "boolean" },
    "viewType": { "schema": "string" },
    "editType": { "schema": "string" },
    "propertyKey": { "schema": "string" },
    "propertyValue": { "schema": "any" },
    "tableId": { "schema": "string" },
    "nCat": { "schema": "string" },
    "key": { "schema": "string" }
  },
  "wfDef": {
    "nodes": [
      {
        "id": "SearchButtonRoot",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "nCat": { "sourceAcId": "$input", "sourcePort": "nCat" },
          "key": { "sourceAcId": "$input", "sourcePort": "key" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "FirstButtonRoot",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "SearchButtonRoot", "sourcePort": "lineIds" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "DeployButton",
        "operation": "DeployBlockWF",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "lineId": { "sourceAcId": "FirstButtonRoot", "sourcePort": "row" }
        },
        "outputs": { "tempTableId": {} },
        "wfCall": { "callee": "DeployBlockWF", "boundary": true }
      },
      {
        "id": "SearchButtonAnchor",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "DeployButton", "sourcePort": "tempTableId" },
          "uCat": { "literal": "button" },
          "parentId": { "sourceAcId": "FirstButtonRoot", "sourcePort": "row" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "FirstButtonAnchor",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "SearchButtonAnchor", "sourcePort": "lineIds" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "RetrieveAnchorKey",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "DeployButton", "sourcePort": "tempTableId" },
          "lineId": { "sourceAcId": "FirstButtonAnchor", "sourcePort": "row" },
          "column": { "literal": "key" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstAnchorKey",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "RetrieveAnchorKey", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "SearchTemplate",
        "operation": "SearchLayoutTemplateTypeAC",
        "deps": {
          "lineKey": { "sourceAcId": "FirstAnchorKey", "sourcePort": "row" }
        },
        "outputs": { "viewTemplateType": {}, "editTemplateType": {} }
      },
      {
        "id": "SearchLabelLine",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "DeployButton", "sourcePort": "tempTableId" },
          "key": { "literal": "label" },
          "parentId": { "sourceAcId": "FirstButtonAnchor", "sourcePort": "row" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "FirstLabelLineId",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "SearchLabelLine", "sourcePort": "lineIds" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "RetrieveLabelValue",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "DeployButton", "sourcePort": "tempTableId" },
          "lineId": { "sourceAcId": "FirstLabelLineId", "sourcePort": "row" },
          "column": { "literal": "value" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstLabelValue",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "RetrieveLabelValue", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "SearchJointIdLine",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "DeployButton", "sourcePort": "tempTableId" },
          "parentId": { "sourceAcId": "FirstButtonAnchor", "sourcePort": "row" },
          "key": { "literal": "joint_id" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "FirstJointIdLineId",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "SearchJointIdLine", "sourcePort": "lineIds" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "RetrieveJointIdValue",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "DeployButton", "sourcePort": "tempTableId" },
          "lineId": { "sourceAcId": "FirstJointIdLineId", "sourcePort": "row" },
          "column": { "literal": "value" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstJointIdValue",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "RetrieveJointIdValue", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "SearchLayout",
        "operation": "SearchLayoutJsonAC",
        "deps": {
          "json": { "sourceAcId": "$input", "sourcePort": "layoutRows" },
          "isRoot": { "sourceAcId": "$input", "sourcePort": "isRoot" },
          "instViewType": { "sourceAcId": "$input", "sourcePort": "viewType" },
          "instEditType": { "sourceAcId": "$input", "sourcePort": "editType" },
          "propertyKey": { "sourceAcId": "$input", "sourcePort": "propertyKey" },
          "propertyValue": { "sourceAcId": "$input", "sourcePort": "propertyValue" }
        },
        "outputs": { "keys": {} }
      },
      {
        "id": "RemoveEndBrackets",
        "operation": "RemoveEndBracketsAC",
        "deps": {
          "blockKey": { "sourceAcId": "$zoneInput", "sourcePort": "blockKeyItem" }
        },
        "outputs": { "parentKey": {} }
      },
      {
        "id": "BuildBlockKey",
        "operation": "BuildLayoutBlockKeyWF",
        "deps": {
          "parentKey": { "sourceAcId": "RemoveEndBrackets", "sourcePort": "parentKey" },
          "blockKey": { "sourceAcId": "FirstButtonAnchor", "sourcePort": "row" }
        },
        "outputs": { "blockKey": {} },
        "wfCall": { "callee": "BuildLayoutBlockKeyWF", "boundary": true }
      },
      {
        "id": "CreateProperty",
        "operation": "CreateLayoutBlockPropertyAC",
        "deps": {
          "tableId": { "sourceAcId": "DeployButton", "sourcePort": "tempTableId" },
          "lineId": { "sourceAcId": "FirstButtonAnchor", "sourcePort": "row" },
          "flowId": { "sourceAcId": "BuildBlockKey", "sourcePort": "blockKey" },
          "buttonLabel": { "sourceAcId": "FirstLabelValue", "sourcePort": "row" },
          "buttonJointId": { "sourceAcId": "FirstJointIdValue", "sourcePort": "row" }
        },
        "outputs": { "property": {} }
      },
      {
        "id": "BuildRow",
        "operation": "BuildLayoutBlockRowAC",
        "deps": {
          "blockKey": { "sourceAcId": "BuildBlockKey", "sourcePort": "blockKey" },
          "viewType": { "sourceAcId": "SearchTemplate", "sourcePort": "viewTemplateType" },
          "editType": { "sourceAcId": "SearchTemplate", "sourcePort": "editTemplateType" },
          "property": { "sourceAcId": "CreateProperty", "sourcePort": "property" }
        },
        "outputs": { "layoutRow": {} }
      },
      {
        "id": "FlattenResults",
        "operation": "FlattenLayoutRowsAC",
        "deps": {
          "nestedRows": { "sourceAcId": "$zone:blockKeyZone", "sourcePort": "allBlockKeyResults" }
        },
        "outputs": { "layoutRows": {} }
      }
    ],
    "forEachZones": [
      {
        "id": "blockKeyZone",
        "collectionSource": {
          "sourceAcId": "SearchLayout",
          "sourcePort": "keys"
        },
        "iterationParam": "blockKeyItem",
        "nodes": ["RemoveEndBrackets", "BuildBlockKey", "CreateProperty", "BuildRow"],
        "outputNodeId": "BuildRow",
        "outputPort": "layoutRow",
        "outputCollection": "allBlockKeyResults"
      }
    ],
    "outputs": {
      "layoutRows": "FlattenResults.layoutRows"
    }
  },
  "wiring": {
    "version": 1,
    "routes": [
      { "id": "R-SearchButtonRoot", "when": { "type": "SearchButtonRoot.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "FirstButtonRoot.rows", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-FirstButtonRoot", "when": { "type": "FirstButtonRoot.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "DeployButton.lineId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }, { "type": "SearchButtonAnchor.parentId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-DeployButton", "when": { "type": "DeployButton.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "SearchButtonAnchor.tableId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }, { "type": "RetrieveAnchorKey.tableId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }, { "type": "SearchLabelLine.tableId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }, { "type": "RetrieveLabelValue.tableId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }, { "type": "SearchJointIdLine.tableId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }, { "type": "RetrieveJointIdValue.tableId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }, { "type": "CreateProperty.tableId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-SearchButtonAnchor", "when": { "type": "SearchButtonAnchor.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "FirstButtonAnchor.rows", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-FirstButtonAnchor", "when": { "type": "FirstButtonAnchor.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "RetrieveAnchorKey.lineId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }, { "type": "SearchLabelLine.parentId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }, { "type": "SearchJointIdLine.parentId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }, { "type": "BuildBlockKey.blockKey", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }, { "type": "CreateProperty.lineId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-RetrieveAnchorKey", "when": { "type": "RetrieveAnchorKey.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "FirstAnchorKey.rows", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-FirstAnchorKey", "when": { "type": "FirstAnchorKey.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "SearchTemplate.lineKey", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-SearchTemplate", "when": { "type": "SearchTemplate.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "BuildRow.viewType", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }, { "type": "BuildRow.editType", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-SearchLabelLine", "when": { "type": "SearchLabelLine.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "FirstLabelLineId.rows", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-FirstLabelLineId", "when": { "type": "FirstLabelLineId.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "RetrieveLabelValue.lineId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-RetrieveLabelValue", "when": { "type": "RetrieveLabelValue.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "FirstLabelValue.rows", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-FirstLabelValue", "when": { "type": "FirstLabelValue.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "CreateProperty.buttonLabel", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-SearchJointIdLine", "when": { "type": "SearchJointIdLine.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "FirstJointIdLineId.rows", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-FirstJointIdLineId", "when": { "type": "FirstJointIdLineId.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "RetrieveJointIdValue.lineId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-RetrieveJointIdValue", "when": { "type": "RetrieveJointIdValue.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "FirstJointIdValue.rows", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-FirstJointIdValue", "when": { "type": "FirstJointIdValue.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "CreateProperty.buttonJointId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-SearchLayout", "when": { "type": "SearchLayout.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "$zone:blockKeyZone.input", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-RemoveEndBrackets", "when": { "type": "RemoveEndBrackets.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "BuildBlockKey.parentKey", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-BuildBlockKey", "when": { "type": "BuildBlockKey.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "CreateProperty.flowId", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }, { "type": "BuildRow.blockKey", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-CreateProperty", "when": { "type": "CreateProperty.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "BuildRow.property", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-BuildRow", "when": { "type": "BuildRow.done" }, "correlate": { "by": ["correlationid"] }, "emit": [] },
      { "id": "R-$zone:blockKeyZone", "when": { "type": "$zone:blockKeyZone.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "FlattenResults.nestedRows", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-FlattenResults", "when": { "type": "FlattenResults.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "wf.completed", "wfid": "BuildLayoutButtonWF", "map": "outputRef->payloadRef" }] }
    ]
  },
  "layout": {
    "viewport": { "x": 0, "y": 0, "zoom": 0.35 },
    "nodes": [
      { "id": "node-start", "type": "ewoStart", "position": { "x": 50, "y": 450 },
        "data": { "inputs": [
          { "name": "layoutRows", "type": "any[]" }, { "name": "isRoot", "type": "boolean" },
          { "name": "viewType", "type": "string" }, { "name": "editType", "type": "string" },
          { "name": "propertyKey", "type": "string" }, { "name": "propertyValue", "type": "any" },
          { "name": "tableId", "type": "string" }, { "name": "nCat", "type": "string" }, { "name": "key", "type": "string" }
        ]}
      },

      { "id": "node-SearchButtonRoot", "type": "ewoAc", "position": { "x": 350, "y": 100 },
        "data": { "label": "SearchButtonRoot", "operation": "SearchLineAC",
          "inputs": [{ "name": "tableId", "type": "string" }, { "name": "nCat", "type": "string" }, { "name": "key", "type": "string" }],
          "outputs": [{ "name": "lineIds", "type": "string[]" }] }},
      { "id": "node-FirstButtonRoot", "type": "ewoAc", "position": { "x": 620, "y": 100 },
        "data": { "label": "FirstButtonRoot", "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }], "outputs": [{ "name": "row", "type": "any" }] }},
      { "id": "node-DeployButton", "type": "ewoWfCall", "position": { "x": 860, "y": 100 },
        "data": { "label": "DeployButton", "operation": "DeployBlockWF",
          "inputs": [{ "name": "tableId", "type": "string" }, { "name": "lineId", "type": "string" }],
          "outputs": [{ "name": "tempTableId", "type": "string" }],
          "wfCall": { "callee": "DeployBlockWF", "boundary": true } }},
      { "id": "node-SearchButtonAnchor", "type": "ewoAc", "position": { "x": 1150, "y": 100 },
        "data": { "label": "SearchButtonAnchor", "operation": "SearchLineAC",
          "inputs": [{ "name": "tableId", "type": "string" }, { "name": "uCat", "type": "string" }, { "name": "parentId", "type": "string" }],
          "outputs": [{ "name": "lineIds", "type": "string[]" }] }},
      { "id": "node-FirstButtonAnchor", "type": "ewoAc", "position": { "x": 1440, "y": 100 },
        "data": { "label": "FirstButtonAnchor", "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }], "outputs": [{ "name": "row", "type": "any" }] }},

      { "id": "node-RetrieveAnchorKey", "type": "ewoAc", "position": { "x": 1730, "y": 100 },
        "data": { "label": "RetrieveAnchorKey", "operation": "RetrieveColumnAC",
          "inputs": [{ "name": "tableId", "type": "string" }, { "name": "lineId", "type": "string" }, { "name": "column", "type": "string" }],
          "outputs": [{ "name": "columns", "type": "any[]" }] }},
      { "id": "node-FirstAnchorKey", "type": "ewoAc", "position": { "x": 2020, "y": 100 },
        "data": { "label": "FirstAnchorKey", "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }], "outputs": [{ "name": "row", "type": "any" }] }},
      { "id": "node-SearchTemplate", "type": "ewoAc", "position": { "x": 2290, "y": 100 },
        "data": { "label": "SearchTemplate", "operation": "SearchLayoutTemplateTypeAC",
          "inputs": [{ "name": "lineKey", "type": "string" }],
          "outputs": [{ "name": "viewTemplateType", "type": "string" }, { "name": "editTemplateType", "type": "string" }] }},

      { "id": "node-SearchLabelLine", "type": "ewoAc", "position": { "x": 1730, "y": 300 },
        "data": { "label": "SearchLabelLine", "operation": "SearchLineAC",
          "inputs": [{ "name": "tableId", "type": "string" }, { "name": "key", "type": "string" }, { "name": "parentId", "type": "string" }],
          "outputs": [{ "name": "lineIds", "type": "string[]" }] }},
      { "id": "node-FirstLabelLineId", "type": "ewoAc", "position": { "x": 2020, "y": 300 },
        "data": { "label": "FirstLabelLineId", "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }], "outputs": [{ "name": "row", "type": "any" }] }},
      { "id": "node-RetrieveLabelValue", "type": "ewoAc", "position": { "x": 2290, "y": 300 },
        "data": { "label": "RetrieveLabelValue", "operation": "RetrieveColumnAC",
          "inputs": [{ "name": "tableId", "type": "string" }, { "name": "lineId", "type": "string" }, { "name": "column", "type": "string" }],
          "outputs": [{ "name": "columns", "type": "any[]" }] }},
      { "id": "node-FirstLabelValue", "type": "ewoAc", "position": { "x": 2570, "y": 300 },
        "data": { "label": "FirstLabelValue", "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }], "outputs": [{ "name": "row", "type": "any" }] }},

      { "id": "node-SearchJointIdLine", "type": "ewoAc", "position": { "x": 1730, "y": 500 },
        "data": { "label": "SearchJointIdLine", "operation": "SearchLineAC",
          "inputs": [{ "name": "tableId", "type": "string" }, { "name": "parentId", "type": "string" }, { "name": "key", "type": "string" }],
          "outputs": [{ "name": "lineIds", "type": "string[]" }] }},
      { "id": "node-FirstJointIdLineId", "type": "ewoAc", "position": { "x": 2020, "y": 500 },
        "data": { "label": "FirstJointIdLineId", "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }], "outputs": [{ "name": "row", "type": "any" }] }},
      { "id": "node-RetrieveJointIdValue", "type": "ewoAc", "position": { "x": 2290, "y": 500 },
        "data": { "label": "RetrieveJointIdValue", "operation": "RetrieveColumnAC",
          "inputs": [{ "name": "tableId", "type": "string" }, { "name": "lineId", "type": "string" }, { "name": "column", "type": "string" }],
          "outputs": [{ "name": "columns", "type": "any[]" }] }},
      { "id": "node-FirstJointIdValue", "type": "ewoAc", "position": { "x": 2570, "y": 500 },
        "data": { "label": "FirstJointIdValue", "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }], "outputs": [{ "name": "row", "type": "any" }] }},

      { "id": "node-SearchLayout", "type": "ewoAc", "position": { "x": 350, "y": 700 },
        "data": { "label": "SearchLayout", "operation": "SearchLayoutJsonAC",
          "inputs": [{ "name": "json", "type": "any[]" }, { "name": "isRoot", "type": "boolean" }, { "name": "instViewType", "type": "string" }, { "name": "instEditType", "type": "string" }],
          "outputs": [{ "name": "keys", "type": "string[]" }] }},

      { "id": "region-blockKeyZone", "type": "ewoForEachRegion", "position": { "x": 700, "y": 650 },
        "style": { "width": "1200px", "height": "250px" },
        "data": { "label": "BlockKeyZone (keys iterate)", "zoneId": "blockKeyZone", "iterationParam": "blockKeyItem", "outputCollection": "allBlockKeyResults" }},
      { "id": "node-RemoveEndBrackets", "type": "ewoAc", "position": { "x": 30, "y": 70 },
        "parentNode": "region-blockKeyZone", "extent": "parent",
        "data": { "label": "RemoveEndBrackets", "operation": "RemoveEndBracketsAC",
          "inputs": [{ "name": "blockKey", "type": "string" }], "outputs": [{ "name": "parentKey", "type": "string" }] }},
      { "id": "node-BuildBlockKey", "type": "ewoWfCall", "position": { "x": 280, "y": 70 },
        "parentNode": "region-blockKeyZone", "extent": "parent",
        "data": { "label": "BuildBlockKey", "operation": "BuildLayoutBlockKeyWF",
          "inputs": [{ "name": "parentKey", "type": "string" }, { "name": "blockKey", "type": "string" }],
          "outputs": [{ "name": "blockKey", "type": "string" }],
          "wfCall": { "callee": "BuildLayoutBlockKeyWF", "boundary": true } }},
      { "id": "node-CreateProperty", "type": "ewoAc", "position": { "x": 560, "y": 70 },
