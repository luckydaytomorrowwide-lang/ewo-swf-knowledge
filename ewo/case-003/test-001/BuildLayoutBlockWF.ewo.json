{
  "id": "BuildLayoutBlockWF",
  "version": "1.0.0",
  "name": "BuildLayoutBlockWF",
  "description": "レイアウトブロックを構築する再帰WF。(1)順序・UCat取得→(2)ガードチェック(UCat!=option)→(3)アンカーキー/行構築→(4)LineZone ForEach[Option検索(OptionZone)→行構築→列処理(ProcessLineColumnsAC)]→(5)RecursiveZone ForEach[自己再帰wfCall]→(6)全結果マージ。",
  "inputs": {
    "tableId": { "schema": "string" },
    "key": { "schema": "string" },
    "nCat": { "schema": "string" },
    "parentId": { "schema": "string" },
    "parentKey": { "schema": "string" },
    "nodeId": { "schema": "string" },
    "nodeLabels": { "schema": "string[]" }
  },
  "wfDef": {
    "nodes": [
      {
        "id": "SearchOrderLine",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "key": { "literal": "order" },
          "nCat": { "literal": "line" },
          "parentId": { "sourceAcId": "$input", "sourcePort": "parentId" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "FirstOrderLineId",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "SearchOrderLine", "sourcePort": "lineIds" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "RetrieveOrderCol",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "lineId": { "sourceAcId": "FirstOrderLineId", "sourcePort": "row" },
          "column": { "literal": "value" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstOrderValue",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "RetrieveOrderCol", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "RetrieveUCatCol",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "lineId": { "sourceAcId": "$input", "sourcePort": "parentId" },
          "column": { "literal": "u_cat" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstUCat",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "RetrieveUCatCol", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },

      {
        "id": "BuildKeyAnchor",
        "operation": "BuildLayoutBlockKeyWF",
        "guard": "FirstUCat.row != 'option'",
        "deps": {
          "parentKey": { "sourceAcId": "$input", "sourcePort": "parentKey" },
          "blockKey": { "sourceAcId": "$input", "sourcePort": "parentId" }
        },
        "outputs": { "blockKey": {} },
        "wfCall": { "callee": "BuildLayoutBlockKeyWF", "boundary": true }
      },
      {
        "id": "BuildRowParent",
        "operation": "BuildLayoutBlockRowWF",
        "guard": "FirstUCat.row != 'option'",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "lineId": { "sourceAcId": "$input", "sourcePort": "parentId" },
          "blockKey": { "sourceAcId": "BuildKeyAnchor", "sourcePort": "blockKey" },
          "instViewType": { "literal": "card" },
          "instEditType": { "literal": "card" },
          "tplViewType": { "literal": "card" },
          "tplEditType": { "literal": "card" },
          "propertyKey": { "literal": "u_cat" },
          "propertyValue": { "sourceAcId": "FirstUCat", "sourcePort": "row" },
          "nodeId": { "sourceAcId": "$input", "sourcePort": "nodeId" },
          "nodeLabels": { "sourceAcId": "$input", "sourcePort": "nodeLabels" },
          "order": { "sourceAcId": "FirstOrderValue", "sourcePort": "row" }
        },
        "outputs": { "layoutRow": {} },
        "wfCall": { "callee": "BuildLayoutBlockRowWF", "boundary": true }
      },
      {
        "id": "SearchLinesForLoop",
        "operation": "SearchLineAC",
        "guard": "FirstUCat.row != 'option'",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "key": { "sourceAcId": "$input", "sourcePort": "key" },
          "nCat": { "literal": "line" },
          "parentId": { "sourceAcId": "$input", "sourcePort": "parentId" }
        },
        "outputs": { "lineIds": {} }
      },

      {
        "id": "SearchOptionAnchors",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "nCat": { "literal": "anchor" },
          "uCat": { "literal": "option" },
          "parentId": { "sourceAcId": "$zoneInput", "sourcePort": "lineItem" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "SearchOptLine",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "nCat": { "literal": "line" },
          "key": { "literal": "value" },
          "parentId": { "sourceAcId": "$zoneInput", "sourcePort": "optAnchorItem" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "FirstOptLineId",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "SearchOptLine", "sourcePort": "lineIds" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "RetrieveOptValue",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "lineId": { "sourceAcId": "FirstOptLineId", "sourcePort": "row" },
          "column": { "literal": "value" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstOptValue",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "RetrieveOptValue", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "ParseOptArray",
        "operation": "ParseToArrayAC",
        "deps": {
          "text": { "sourceAcId": "FirstOptValue", "sourcePort": "row" }
        },
        "outputs": { "array": {} }
      },

      {
        "id": "BuildKeyLine",
        "operation": "BuildLayoutBlockKeyWF",
        "deps": {
          "parentKey": { "sourceAcId": "BuildKeyAnchor", "sourcePort": "blockKey" },
          "blockKey": { "sourceAcId": "$zoneInput", "sourcePort": "lineItem" }
        },
        "outputs": { "blockKey": {} },
        "wfCall": { "callee": "BuildLayoutBlockKeyWF", "boundary": true }
      },
      {
        "id": "BuildRowLine",
        "operation": "BuildLayoutBlockRowWF",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "lineId": { "sourceAcId": "$zoneInput", "sourcePort": "lineItem" },
          "blockKey": { "sourceAcId": "BuildKeyLine", "sourcePort": "blockKey" },
          "instViewType": { "literal": "card" },
          "instEditType": { "literal": "card" },
          "tplViewType": { "literal": "card" },
          "tplEditType": { "literal": "card" },
          "layoutProperty": { "literal": { "layout": "grid" } },
          "propertyKey": { "literal": "u_cat" },
          "propertyValue": { "sourceAcId": "FirstUCat", "sourcePort": "row" },
          "nodeId": { "sourceAcId": "$input", "sourcePort": "nodeId" },
          "nodeLabels": { "sourceAcId": "$input", "sourcePort": "nodeLabels" },
          "nCat": { "literal": "line" }
        },
        "outputs": { "layoutRow": {} },
        "wfCall": { "callee": "BuildLayoutBlockRowWF", "boundary": true }
      },
      {
        "id": "RetrieveKeyCellCol",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "lineId": { "sourceAcId": "$zoneInput", "sourcePort": "lineItem" },
          "column": { "literal": "key" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstKeyCell",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "RetrieveKeyCellCol", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "ProcessLineColumns",
        "operation": "ProcessLineColumnsAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "lineId": { "sourceAcId": "$zoneInput", "sourcePort": "lineItem" },
          "blockKeyLine": { "sourceAcId": "BuildKeyLine", "sourcePort": "blockKey" },
          "keyCell": { "sourceAcId": "FirstKeyCell", "sourcePort": "row" },
          "anchorUcat": { "sourceAcId": "FirstUCat", "sourcePort": "row" },
          "optionValues": { "sourceAcId": "$zone:optionZone", "sourcePort": "optionValues" },
          "nodeId": { "sourceAcId": "$input", "sourcePort": "nodeId" },
          "nodeLabels": { "sourceAcId": "$input", "sourcePort": "nodeLabels" }
        },
        "outputs": { "layoutRows": {} }
      },
      {
        "id": "AssembleLineResults",
        "operation": "AssembleLineResultsAC",
        "deps": {
          "lineRow": { "sourceAcId": "BuildRowLine", "sourcePort": "layoutRow" },
          "columnRows": { "sourceAcId": "ProcessLineColumns", "sourcePort": "layoutRows" }
        },
        "outputs": { "lineLayoutRows": {} }
      },

      {
        "id": "SearchAnchorsForRecursion",
        "operation": "SearchLineAC",
        "guard": "FirstUCat.row != 'option'",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "nCat": { "sourceAcId": "$input", "sourcePort": "nCat" },
          "key": { "sourceAcId": "$input", "sourcePort": "key" },
          "parentId": { "sourceAcId": "$input", "sourcePort": "parentId" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "RecursiveCall",
        "operation": "BuildLayoutBlockWF",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "key": { "sourceAcId": "$input", "sourcePort": "key" },
          "nCat": { "sourceAcId": "$input", "sourcePort": "nCat" },
          "parentId": { "sourceAcId": "$zoneInput", "sourcePort": "anchorItem" },
          "parentKey": { "sourceAcId": "BuildKeyAnchor", "sourcePort": "blockKey" },
          "nodeId": { "sourceAcId": "$input", "sourcePort": "nodeId" },
          "nodeLabels": { "sourceAcId": "$input", "sourcePort": "nodeLabels" }
        },
        "outputs": { "layoutRows": {} },
        "wfCall": {
          "callee": "BuildLayoutBlockWF",
          "boundary": true,
          "recursive": true,
          "policy": { "maxRecursionDepth": 20 }
        }
      },

      {
        "id": "MergeAllResults",
        "operation": "MergeLayoutRowsAC",
        "deps": {
          "parentRow": { "sourceAcId": "BuildRowParent", "sourcePort": "layoutRow" },
          "lineResults": { "sourceAcId": "$zone:lineZone", "sourcePort": "allLineResults" },
          "recursiveResults": { "sourceAcId": "$zone:recursiveZone", "sourcePort": "allRecursiveResults" }
        },
        "outputs": { "layoutRows": {} }
      }
    ],
    "forEachZones": [
      {
        "id": "lineZone",
        "collectionSource": {
          "sourceAcId": "SearchLinesForLoop",
          "sourcePort": "lineIds"
        },
        "iterationParam": "lineItem",
        "nodes": [
          "SearchOptionAnchors", "BuildKeyLine", "BuildRowLine",
          "RetrieveKeyCellCol", "FirstKeyCell",
          "ProcessLineColumns", "AssembleLineResults"
        ],
        "childZones": [
          {
            "id": "optionZone",
            "collectionSource": {
              "sourceAcId": "SearchOptionAnchors",
              "sourcePort": "lineIds"
            },
            "iterationParam": "optAnchorItem",
            "nodes": [
              "SearchOptLine", "FirstOptLineId",
              "RetrieveOptValue", "FirstOptValue", "ParseOptArray"
            ],
            "outputNodeId": "ParseOptArray",
            "outputPort": "array",
            "outputCollection": "optionValues"
          }
        ],
        "outputNodeId": "AssembleLineResults",
        "outputPort": "lineLayoutRows",
        "outputCollection": "allLineResults"
      },
      {
        "id": "recursiveZone",
        "collectionSource": {
          "sourceAcId": "SearchAnchorsForRecursion",
          "sourcePort": "lineIds"
        },
        "iterationParam": "anchorItem",
        "nodes": ["RecursiveCall"],
        "outputNodeId": "RecursiveCall",
        "outputPort": "layoutRows",
        "outputCollection": "allRecursiveResults"
      }
    ],
    "outputs": {
      "layoutRows": "MergeAllResults.layoutRows"
    }
  },
  "wiring": {
    "version": 1,
    "routes": [
      {
        "id": "R-SearchOrderLine",
        "when": { "type": "SearchOrderLine.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstOrderLineId.rows", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstOrderLineId",
        "when": { "type": "FirstOrderLineId.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "RetrieveOrderCol.lineId", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-RetrieveOrderCol",
        "when": { "type": "RetrieveOrderCol.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstOrderValue.rows", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstOrderValue",
        "when": { "type": "FirstOrderValue.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "BuildRowParent.order", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-RetrieveUCatCol",
        "when": { "type": "RetrieveUCatCol.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstUCat.rows", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstUCat",
        "when": { "type": "FirstUCat.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "BuildRowParent.propertyValue", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" },
          { "type": "BuildRowLine.propertyValue", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" },
          { "type": "ProcessLineColumns.anchorUcat", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-BuildKeyAnchor",
        "when": { "type": "BuildKeyAnchor.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "BuildRowParent.blockKey", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" },
          { "type": "BuildKeyLine.parentKey", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" },
          { "type": "RecursiveCall.parentKey", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-BuildRowParent",
        "when": { "type": "BuildRowParent.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "MergeAllResults.parentRow", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-SearchLinesForLoop",
        "when": { "type": "SearchLinesForLoop.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "$zone:lineZone.input", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-SearchOptionAnchors",
        "when": { "type": "SearchOptionAnchors.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "$zone:optionZone.input", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-SearchOptLine",
        "when": { "type": "SearchOptLine.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstOptLineId.rows", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstOptLineId",
        "when": { "type": "FirstOptLineId.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "RetrieveOptValue.lineId", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-RetrieveOptValue",
        "when": { "type": "RetrieveOptValue.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstOptValue.rows", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstOptValue",
        "when": { "type": "FirstOptValue.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "ParseOptArray.text", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-ParseOptArray",
        "when": { "type": "ParseOptArray.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": []
      },
      {
        "id": "R-$zone:optionZone",
        "when": { "type": "$zone:optionZone.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "ProcessLineColumns.optionValues", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-BuildKeyLine",
        "when": { "type": "BuildKeyLine.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "BuildRowLine.blockKey", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" },
          { "type": "ProcessLineColumns.blockKeyLine", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-BuildRowLine",
        "when": { "type": "BuildRowLine.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "AssembleLineResults.lineRow", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-RetrieveKeyCellCol",
        "when": { "type": "RetrieveKeyCellCol.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstKeyCell.rows", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstKeyCell",
        "when": { "type": "FirstKeyCell.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "ProcessLineColumns.keyCell", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-ProcessLineColumns",
        "when": { "type": "ProcessLineColumns.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "AssembleLineResults.columnRows", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-AssembleLineResults",
        "when": { "type": "AssembleLineResults.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": []
      },
      {
        "id": "R-$zone:lineZone",
        "when": { "type": "$zone:lineZone.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "MergeAllResults.lineResults", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-SearchAnchorsForRecursion",
        "when": { "type": "SearchAnchorsForRecursion.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "$zone:recursiveZone.input", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-RecursiveCall",
        "when": { "type": "RecursiveCall.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": []
      },
      {
        "id": "R-$zone:recursiveZone",
        "when": { "type": "$zone:recursiveZone.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "MergeAllResults.recursiveResults", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-MergeAllResults",
        "when": { "type": "MergeAllResults.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "wf.completed", "wfid": "BuildLayoutBlockWF", "map": "outputRef->payloadRef" }
        ]
      }
    ]
  },
  "layout": {
    "viewport": { "x": 0, "y": 0, "zoom": 0.45 },
    "nodes": [
      {
        "id": "node-start",
        "type": "ewoStart",
        "position": { "x": 50, "y": 450 },
        "data": {
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "key", "type": "string" },
            { "name": "nCat", "type": "string" },
            { "name": "parentId", "type": "string" },
            { "name": "parentKey", "type": "string" },
            { "name": "nodeId", "type": "string" },
            { "name": "nodeLabels", "type": "string[]" }
          ]
        }
      },

      {
        "id": "node-SearchOrderLine",
        "type": "ewoAc",
        "position": { "x": 300, "y": 150 },
        "data": {
          "label": "SearchOrderLine",
          "operation": "SearchLineAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "key", "type": "string" },
            { "name": "nCat", "type": "string" },
            { "name": "parentId", "type": "string" }
          ],
          "outputs": [{ "name": "lineIds", "type": "string[]" }]
        }
      },
      {
        "id": "node-FirstOrderLineId",
        "type": "ewoAc",
        "position": { "x": 540, "y": 150 },
        "data": {
          "label": "FirstOrderLineId",
          "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }],
          "outputs": [{ "name": "row", "type": "any" }]
        }
      },
      {
        "id": "node-RetrieveOrderCol",
        "type": "ewoAc",
        "position": { "x": 780, "y": 150 },
        "data": {
          "label": "RetrieveOrderCol",
          "operation": "RetrieveColumnAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "lineId", "type": "string" },
            { "name": "column", "type": "string" }
          ],
          "outputs": [{ "name": "columns", "type": "any[]" }]
        }
      },
      {
        "id": "node-FirstOrderValue",
        "type": "ewoAc",
        "position": { "x": 1020, "y": 150 },
        "data": {
          "label": "FirstOrderValue",
          "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }],
          "outputs": [{ "name": "row", "type": "any" }]
        }
      },

      {
