{
  "id": "GetPageTableWF",
  "version": "1.0.0",
  "name": "GetPageTableWF",
  "description": "ページテーブルを取得するWF。pageIdからノードのdataプロパティを取得し、一時テーブルに登録。structテーブルとdataテーブルを取得・登録し、マージしたテーブルを返す。",
  "inputs": {
    "pageId": { "schema": "string?" }
  },
  "wfDef": {
    "nodes": [
      {
        "id": "GetPageId",
        "operation": "GetPageIdAC",
        "guard": "$input.pageId == undefined",
        "deps": {},
        "outputs": { "pageId": {} }
      },
      {
        "id": "SearchPage",
        "operation": "SearchNodeAC",
        "deps": {
          "nodeId": { "oneOf": [
            { "sourceAcId": "$input", "sourcePort": "pageId" },
            { "sourceAcId": "GetPageId", "sourcePort": "pageId" }
          ]}
        },
        "outputs": { "nodeIds": {} }
      },
      {
        "id": "FirstSearchResult",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "SearchPage", "sourcePort": "nodeIds" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "GetNodeProperty",
        "operation": "GetNodePropertyAC",
        "deps": {
          "nodeId": { "sourceAcId": "FirstSearchResult", "sourcePort": "row" },
          "property": { "literal": "data" }
        },
        "outputs": { "value": {} }
      },
      {
        "id": "CreateUlid",
        "operation": "CreateUlidAC",
        "deps": {},
        "outputs": { "ulid": {} }
      },
      {
        "id": "BuildTempTableId",
        "operation": "BuildTemporaryTableIdAC",
        "deps": {
          "tableId": { "literal": "data_property" },
          "ulid": { "sourceAcId": "CreateUlid", "sourcePort": "ulid" }
        },
        "outputs": { "tempTableId": {} }
      },
      {
        "id": "RegisterTemp",
        "operation": "RegisterTemporaryAC",
        "deps": {
          "tableId": { "sourceAcId": "BuildTempTableId", "sourcePort": "tempTableId" },
          "rows": { "sourceAcId": "GetNodeProperty", "sourcePort": "value" }
        },
        "outputs": { "tableId": {} }
      },
      {
        "id": "SearchTableIdLine",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "RegisterTemp", "sourcePort": "tableId" },
          "key": { "literal": "tableId" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "FirstTableIdLine",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "SearchTableIdLine", "sourcePort": "lineIds" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "RetrieveTableIdCol",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "BuildTempTableId", "sourcePort": "tempTableId" },
          "lineId": { "sourceAcId": "FirstTableIdLine", "sourcePort": "row" },
          "column": { "literal": "value" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstStructTableId",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "RetrieveTableIdCol", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "RetrieveStructTable",
        "operation": "RetrieveTableAC",
        "deps": {
          "tableId": { "sourceAcId": "FirstStructTableId", "sourcePort": "row" }
        },
        "outputs": { "rows": {} }
      },
      {
        "id": "RegisterStruct",
        "operation": "RegisterStructAC",
        "deps": {
          "rows": { "sourceAcId": "RetrieveStructTable", "sourcePort": "rows" }
        },
        "outputs": {}
      },
      {
        "id": "ConvertToDataTableName",
        "operation": "ConvertStructToDataTableNameAC",
        "deps": {
          "tableId": { "sourceAcId": "FirstStructTableId", "sourcePort": "row" }
        },
        "outputs": { "dataTableId": {} }
      },
      {
        "id": "RetrieveDataTable",
        "operation": "RetrieveTableAC",
        "deps": {
          "tableId": { "sourceAcId": "ConvertToDataTableName", "sourcePort": "dataTableId" }
        },
        "outputs": { "rows": {} }
      },
      {
        "id": "RegisterData",
        "operation": "RegisterDataAC",
        "deps": {
          "rows": { "sourceAcId": "RetrieveDataTable", "sourcePort": "rows" }
        },
        "outputs": {}
      },
      {
        "id": "BuildMergedTableId",
        "operation": "BuildTemporaryTableIdAC",
        "deps": {
          "tableId": { "sourceAcId": "FirstStructTableId", "sourcePort": "row" },
          "ulid": { "sourceAcId": "CreateUlid", "sourcePort": "ulid" }
        },
        "outputs": { "tempTableId": {} }
      },
      {
        "id": "MergeTable",
        "operation": "MergeTableAC",
        "deps": {
          "structTableId": { "sourceAcId": "FirstStructTableId", "sourcePort": "row" },
          "dataTableId": { "sourceAcId": "ConvertToDataTableName", "sourcePort": "dataTableId" }
        },
        "outputs": { "rows": {} }
      },
      {
        "id": "RegisterMerged",
        "operation": "RegisterTemporaryAC",
        "deps": {
          "tableId": { "sourceAcId": "BuildMergedTableId", "sourcePort": "tempTableId" },
          "rows": { "sourceAcId": "MergeTable", "sourcePort": "rows" }
        },
        "outputs": { "tableId": {} }
      }
    ],
    "outputs": {
      "tableId": "RegisterMerged.tableId"
    }
  },
  "wiring": {
    "version": 1,
    "routes": [
      {
        "id": "R-GetPageId",
        "when": { "type": "GetPageId.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "SearchPage.nodeId", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-SearchPage",
        "when": { "type": "SearchPage.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstSearchResult.rows", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstSearchResult",
        "when": { "type": "FirstSearchResult.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "GetNodeProperty.nodeId", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-GetNodeProperty",
        "when": { "type": "GetNodeProperty.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "RegisterTemp.rows", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-CreateUlid",
        "when": { "type": "CreateUlid.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "BuildTempTableId.ulid", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" },
          { "type": "BuildMergedTableId.ulid", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-BuildTempTableId",
        "when": { "type": "BuildTempTableId.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "RegisterTemp.tableId", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" },
          { "type": "RetrieveTableIdCol.tableId", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-RegisterTemp",
        "when": { "type": "RegisterTemp.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "SearchTableIdLine.tableId", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-SearchTableIdLine",
        "when": { "type": "SearchTableIdLine.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstTableIdLine.rows", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstTableIdLine",
        "when": { "type": "FirstTableIdLine.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "RetrieveTableIdCol.lineId", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-RetrieveTableIdCol",
        "when": { "type": "RetrieveTableIdCol.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstStructTableId.rows", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstStructTableId",
        "when": { "type": "FirstStructTableId.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "RetrieveStructTable.tableId", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" },
          { "type": "ConvertToDataTableName.tableId", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" },
          { "type": "BuildMergedTableId.tableId", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" },
          { "type": "MergeTable.structTableId", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-RetrieveStructTable",
        "when": { "type": "RetrieveStructTable.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "RegisterStruct.rows", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-RegisterStruct",
        "when": { "type": "RegisterStruct.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": []
      },
      {
        "id": "R-ConvertToDataTableName",
        "when": { "type": "ConvertToDataTableName.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "RetrieveDataTable.tableId", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" },
          { "type": "MergeTable.dataTableId", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-RetrieveDataTable",
        "when": { "type": "RetrieveDataTable.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "RegisterData.rows", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-RegisterData",
        "when": { "type": "RegisterData.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": []
      },
      {
        "id": "R-BuildMergedTableId",
        "when": { "type": "BuildMergedTableId.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "RegisterMerged.tableId", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-MergeTable",
        "when": { "type": "MergeTable.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "RegisterMerged.rows", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-RegisterMerged",
        "when": { "type": "RegisterMerged.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "wf.completed", "wfid": "GetPageTableWF", "map": "outputRef->payloadRef" }
        ]
      }
    ]
  },
