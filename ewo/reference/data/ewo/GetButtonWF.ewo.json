          ]
        }
      },
      {
        "id": "node-end",
        "type": "ewoEnd",
        "position": { "x": 1870, "y": 250 },
        "data": {
          "outputs": [
            { "name": "text", "type": "any" },
            { "name": "jointId", "type": "any" }
          ]
        }
      }
    ],
    "edges": [
      { "id": "e-start-SBA", "source": "node-start", "target": "node-SearchButtonAnchors", "sourceHandle": "output-arg1", "targetHandle": "input-tableId" },
      { "id": "e-start-SBA-parentId", "source": "node-start", "target": "node-SearchButtonAnchors", "sourceHandle": "output-arg2", "targetHandle": "input-parentId" },
      { "id": "e-SBA-FBA", "source": "node-SearchButtonAnchors", "target": "node-FirstButtonAnchor", "sourceHandle": "output-lineIds", "targetHandle": "input-rows" },
      { "id": "e-FBA-SLL", "source": "node-FirstButtonAnchor", "target": "node-SearchLabelLines", "sourceHandle": "output-row", "targetHandle": "input-parentId" },
      { "id": "e-SLL-FLL", "source": "node-SearchLabelLines", "target": "node-FirstLabelLine", "sourceHandle": "output-lineIds", "targetHandle": "input-rows" },
      { "id": "e-FLL-RLC", "source": "node-FirstLabelLine", "target": "node-RetrieveLabelCol", "sourceHandle": "output-row", "targetHandle": "input-lineId" },
      { "id": "e-RLC-FLV", "source": "node-RetrieveLabelCol", "target": "node-FirstLabelValue", "sourceHandle": "output-columns", "targetHandle": "input-rows" },
      { "id": "e-FLV-end", "source": "node-FirstLabelValue", "target": "node-end", "sourceHandle": "output-row", "targetHandle": "input-text" },
      { "id": "e-FBA-SJL", "source": "node-FirstButtonAnchor", "target": "node-SearchJointLines", "sourceHandle": "output-row", "targetHandle": "input-parentId" },
      { "id": "e-SJL-FJL", "source": "node-SearchJointLines", "target": "node-FirstJointLine", "sourceHandle": "output-lineIds", "targetHandle": "input-rows" },
      { "id": "e-FJL-RJC", "source": "node-FirstJointLine", "target": "node-RetrieveJointCol", "sourceHandle": "output-row", "targetHandle": "input-lineId" },
      { "id": "e-RJC-FJV", "source": "node-RetrieveJointCol", "target": "node-FirstJointValue", "sourceHandle": "output-columns", "targetHandle": "input-rows" },
      { "id": "e-FJV-end", "source": "node-FirstJointValue", "target": "node-end", "sourceHandle": "output-row", "targetHandle": "input-jointId" }
