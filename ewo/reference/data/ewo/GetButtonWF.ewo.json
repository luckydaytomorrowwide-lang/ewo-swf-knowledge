      {
        "id": "node-RetrieveJointCol",
        "type": "ewoAc",
        "position": { "x": 1350, "y": 380 },
        "data": {
          "label": "RetrieveJointCol",
          "operation": "RetrieveColumnAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "lineId", "type": "string" },
            { "name": "column", "type": "string" }
          ],
          "outputs": [
            { "name": "columns", "type": "any[]" }
          ]
        }
      },
      {
        "id": "node-FirstJointValue",
        "type": "ewoAc",
        "position": { "x": 1610, "y": 380 },
        "data": {
          "label": "FirstJointValue",
          "operation": "FirstRowAC",
          "inputs": [
            { "name": "rows", "type": "any[]" }
          ],
