        "correlate": { "by": ["correlationid"] },
        "emit": []
      },
      {
        "id": "R-$zone:childZone",
        "when": { "type": "$zone:childZone.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "CollectChildValues.values", "wfid": "GetAnchorsWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-CollectChildValues",
