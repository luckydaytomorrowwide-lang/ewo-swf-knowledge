{
  "id": "GetAnchorsWF",
  "version": "1.0.0",
  "name": "GetAnchorsWF",
  "description": "è¦ھVAR_NAMEمƒ©م‚¤مƒ³م‚’Searchمپ—م€پ3و®µéڑژمƒچم‚¹مƒˆForEach: parentLineâ†’parentAnchorâ†’childAnchorمپ§هگ„childAnchorمپ®VAR_NAMEه€¤م‚’هڈژé›†مپ™م‚‹م€‚",
  "inputs": {
    "arg1": { "schema": "string" },
    "arg2": { "schema": "string" },
    "arg3": { "schema": "string" },
    "arg4": { "schema": "string" }
  },
  "wfDef": {
    "nodes": [
      {
        "id": "SearchParentLines",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "tableType": { "literal": 3 },
          "key": { "literal": "VAR_NAME" },
          "value": { "sourceAcId": "$input", "sourcePort": "arg2" }
        },
        "outputs": { "lineIds": {} }
      },

      {
        "id": "RetrieveParentIdCol",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "tableType": { "literal": 3 },
          "lineId": { "sourceAcId": "$zoneInput", "sourcePort": "parentLine" },
          "column": { "literal": "parent_id" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstParentId",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "RetrieveParentIdCol", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "SearchParentAnchors",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "tableType": { "literal": 3 },
          "lineId": { "sourceAcId": "FirstParentId", "sourcePort": "row" },
          "nCat": { "literal": "anchor" },
          "uCat": { "sourceAcId": "$input", "sourcePort": "arg3" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "FlattenInnerValues",
        "operation": "FlattenArrayAC",
        "deps": {
          "nested": { "sourceAcId": "$zone:innerZone", "sourcePort": "innerValues" }
        },
        "outputs": { "values": {} }
      },

      {
        "id": "SearchChildAnchors",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "tableType": { "literal": 3 },
          "parentId": { "sourceAcId": "$zoneInput", "sourcePort": "parentAnchor" },
          "nCat": { "literal": "anchor" },
          "uCat": { "sourceAcId": "$input", "sourcePort": "arg4" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "CollectChildValues",
        "operation": "CollectValuesAC",
        "deps": {
          "values": { "sourceAcId": "$zone:childZone", "sourcePort": "childValues" }
        },
        "outputs": { "values": {} }
      },

      {
        "id": "SearchChildVarLine",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "tableType": { "literal": 3 },
          "parentId": { "sourceAcId": "$zoneInput", "sourcePort": "childAnchor" },
          "nCat": { "literal": "line" },
          "key": { "literal": "VAR_NAME" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "FirstChildLine",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "SearchChildVarLine", "sourcePort": "lineIds" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "RetrieveChildValueCol",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "tableType": { "literal": 3 },
          "lineId": { "sourceAcId": "FirstChildLine", "sourcePort": "row" },
          "column": { "literal": "value" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstChildValue",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "RetrieveChildValueCol", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },

      {
        "id": "FlattenAllValues",
        "operation": "FlattenArrayAC",
        "deps": {
          "nested": { "sourceAcId": "$zone:outerZone", "sourcePort": "allValues" }
        },
        "outputs": { "values": {} }
      }
    ],
    "forEachZones": [
      {
        "id": "outerZone",
        "collectionSource": {
          "sourceAcId": "SearchParentLines",
          "sourcePort": "lineIds"
        },
        "iterationParam": "parentLine",
        "nodes": ["RetrieveParentIdCol", "FirstParentId", "SearchParentAnchors", "FlattenInnerValues"],
        "childZones": [
          {
            "id": "innerZone",
