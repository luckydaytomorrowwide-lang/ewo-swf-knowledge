        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FlattenAllValues.nested", "wfid": "GetAnchorsWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FlattenAllValues",
        "when": { "type": "FlattenAllValues.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "wf.completed", "wfid": "GetAnchorsWF", "map": "outputRef->payloadRef" }
        ]
      }
    ]
