            "outputNodeId": "CollectChildValues",
            "outputPort": "values",
            "outputCollection": "innerValues"
          }
        ],
        "outputNodeId": "FlattenInnerValues",
        "outputPort": "values",
        "outputCollection": "allValues"
      }
    ],
    "outputs": {
      "values": "FlattenAllValues.values"
    }
  },
