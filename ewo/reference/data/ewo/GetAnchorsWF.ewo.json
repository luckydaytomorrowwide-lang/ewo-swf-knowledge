      },
      {
        "id": "R-$zone:innerZone",
        "when": { "type": "$zone:innerZone.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FlattenInnerValues.nested", "wfid": "GetAnchorsWF", "map": "outputRef->payloadRef" }
        ]
