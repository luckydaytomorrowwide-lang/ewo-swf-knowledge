{
  "id": "GetTabWF",
  "version": "1.0.0",
  "name": "GetTabWF",
  "description": "VAR_NAMEでテーブル行を検索し、タブのテキストとjointIdを取得する。varNameUlidsをForEachでiterate。",
  "inputs": {
    "arg1": { "schema": "string" },
    "arg2": { "schema": "string" }
  },
  "wfDef": {
    "nodes": [
      {
        "id": "SearchVarNames",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "tableType": { "literal": 3 },
          "key": { "literal": "VAR_NAME" },
          "value": { "sourceAcId": "$input", "sourcePort": "arg2" }
        },
        "outputs": { "lineIds": {} }
      },

      {
        "id": "GetParentId",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "tableType": { "literal": 3 },
          "lineId": { "sourceAcId": "$zoneInput", "sourcePort": "varNameItem" },
          "column": { "literal": "parent_id" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstParent",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "GetParentId", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "SearchAnchor",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "tableType": { "literal": 3 },
          "lineId": { "sourceAcId": "FirstParent", "sourcePort": "row" },
          "nCat": { "literal": "anchor" },
          "uCat": { "literal": "tab" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "FirstAnchor",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "SearchAnchor", "sourcePort": "lineIds" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "GetDepId",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "tableType": { "literal": 3 },
          "lineId": { "sourceAcId": "FirstAnchor", "sourcePort": "row" },
          "column": { "literal": "dep_id" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstJointId",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "GetDepId", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "SearchLabel",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "tableType": { "literal": 3 },
          "parentId": { "sourceAcId": "FirstAnchor", "sourcePort": "row" },
          "key": { "literal": "label" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "FirstLabelLine",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "SearchLabel", "sourcePort": "lineIds" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "GetLabelValue",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "tableType": { "literal": 3 },
          "lineId": { "sourceAcId": "FirstLabelLine", "sourcePort": "row" },
          "column": { "literal": "value" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstText",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "GetLabelValue", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "PackResult",
        "operation": "PackFieldsAC",
        "deps": {
          "text": { "sourceAcId": "FirstText", "sourcePort": "row" },
          "jointId": { "sourceAcId": "FirstJointId", "sourcePort": "row" }
        },
        "outputs": { "packed": {} }
      },

      {
        "id": "GetFirstResult",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "$zone:varNameZone", "sourcePort": "allResults" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "UnpackResult",
        "operation": "UnpackResultAC",
        "deps": {
          "packed": { "sourceAcId": "GetFirstResult", "sourcePort": "row" }
        },
        "outputs": { "text": {}, "jointId": {} }
      }
    ],
    "forEachZones": [
      {
        "id": "varNameZone",
        "collectionSource": {
          "sourceAcId": "SearchVarNames",
          "sourcePort": "lineIds"
        },
        "iterationParam": "varNameItem",
        "nodes": [
          "GetParentId", "FirstParent", "SearchAnchor", "FirstAnchor",
          "GetDepId", "FirstJointId",
          "SearchLabel", "FirstLabelLine", "GetLabelValue", "FirstText",
          "PackResult"
        ],
        "outputNodeId": "PackResult",
        "outputPort": "packed",
        "outputCollection": "allResults"
      }
    ],
    "outputs": {
      "text": "UnpackResult.text",
      "jointId": "UnpackResult.jointId"
    }
  },
  "wiring": {
    "version": 1,
    "routes": [
      {
        "id": "R-SearchVarNames",
        "when": { "type": "SearchVarNames.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "$zone:varNameZone.input", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-GetParentId",
        "when": { "type": "GetParentId.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstParent.rows", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstParent",
        "when": { "type": "FirstParent.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "SearchAnchor.lineId", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-SearchAnchor",
        "when": { "type": "SearchAnchor.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstAnchor.rows", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstAnchor",
        "when": { "type": "FirstAnchor.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "GetDepId.lineId", "wfid": "GetTabWF", "map": "outputRef->payloadRef" },
          { "type": "SearchLabel.parentId", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-GetDepId",
        "when": { "type": "GetDepId.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstJointId.rows", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstJointId",
        "when": { "type": "FirstJointId.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "PackResult.jointId", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-SearchLabel",
        "when": { "type": "SearchLabel.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstLabelLine.rows", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstLabelLine",
        "when": { "type": "FirstLabelLine.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "GetLabelValue.lineId", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-GetLabelValue",
        "when": { "type": "GetLabelValue.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstText.rows", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstText",
        "when": { "type": "FirstText.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "PackResult.text", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-PackResult",
        "when": { "type": "PackResult.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": []
      },
      {
        "id": "R-$zone:varNameZone",
        "when": { "type": "$zone:varNameZone.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "GetFirstResult.rows", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-GetFirstResult",
        "when": { "type": "GetFirstResult.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "UnpackResult.packed", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-UnpackResult",
        "when": { "type": "UnpackResult.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "wf.completed", "wfid": "GetTabWF", "map": "outputRef->payloadRef" }
        ]
      }
    ]
  },
  "layout": {
    "viewport": { "x": 0, "y": 0, "zoom": 0.4 },
    "nodes": [
      {
        "id": "node-start",
        "type": "ewoStart",
        "position": { "x": 50, "y": 300 },
        "data": {
          "inputs": [
            { "name": "arg1", "type": "string" },
            { "name": "arg2", "type": "string" }
          ]
        }
      },
      {
        "id": "node-SearchVarNames",
        "type": "ewoAc",
        "position": { "x": 260, "y": 300 },
        "data": {
          "label": "SearchVarNames",
          "operation": "SearchLineAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "tableType", "type": "number" },
            { "name": "key", "type": "string" },
            { "name": "value", "type": "string" }
          ],
          "outputs": [{ "name": "lineIds", "type": "string[]" }]
        }
      },
      {
        "id": "region-varNameZone",
        "type": "ewoForEachRegion",
        "position": { "x": 500, "y": 30 },
        "style": { "width": "2100px", "height": "500px" },
        "data": {
          "label": "VarNameZone (varNameUlids iterate)",
          "zoneId": "varNameZone",
          "iterationParam": "varNameItem",
          "outputCollection": "allResults"
        }
      },
      {
        "id": "node-GetParentId",
        "type": "ewoAc",
        "position": { "x": 40, "y": 140 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "GetParentId",
          "operation": "RetrieveColumnAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "tableType", "type": "number" },
            { "name": "lineId", "type": "string" },
            { "name": "column", "type": "string" }
          ],
          "outputs": [{ "name": "columns", "type": "any[]" }]
        }
      },
      {
        "id": "node-FirstParent",
        "type": "ewoAc",
        "position": { "x": 260, "y": 140 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "FirstParent",
          "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }],
          "outputs": [{ "name": "row", "type": "any" }]
        }
      },
      {
        "id": "node-SearchAnchor",
        "type": "ewoAc",
        "position": { "x": 460, "y": 140 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "SearchAnchor",
          "operation": "SearchLineAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "tableType", "type": "number" },
            { "name": "lineId", "type": "string" },
            { "name": "nCat", "type": "string" },
            { "name": "uCat", "type": "string" }
          ],
          "outputs": [{ "name": "lineIds", "type": "string[]" }]
        }
      },
      {
        "id": "node-FirstAnchor",
        "type": "ewoAc",
        "position": { "x": 680, "y": 140 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "FirstAnchor",
          "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }],
          "outputs": [{ "name": "row", "type": "any" }]
        }
      },
      {
        "id": "node-GetDepId",
        "type": "ewoAc",
        "position": { "x": 900, "y": 60 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "GetDepId",
          "operation": "RetrieveColumnAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "tableType", "type": "number" },
            { "name": "lineId", "type": "string" },
            { "name": "column", "type": "string" }
          ],
          "outputs": [{ "name": "columns", "type": "any[]" }]
        }
      },
      {
        "id": "node-FirstJointId",
        "type": "ewoAc",
        "position": { "x": 1120, "y": 60 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "FirstJointId",
          "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }],
          "outputs": [{ "name": "row", "type": "any" }]
        }
      },
      {
        "id": "node-SearchLabel",
        "type": "ewoAc",
        "position": { "x": 900, "y": 250 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "SearchLabel",
          "operation": "SearchLineAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "tableType", "type": "number" },
            { "name": "parentId", "type": "string" },
            { "name": "key", "type": "string" }
          ],
          "outputs": [{ "name": "lineIds", "type": "string[]" }]
        }
      },
      {
        "id": "node-FirstLabelLine",
        "type": "ewoAc",
        "position": { "x": 1120, "y": 250 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "FirstLabelLine",
          "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }],
          "outputs": [{ "name": "row", "type": "any" }]
        }
      },
      {
        "id": "node-GetLabelValue",
        "type": "ewoAc",
        "position": { "x": 1340, "y": 250 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "GetLabelValue",
          "operation": "RetrieveColumnAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "tableType", "type": "number" },
            { "name": "lineId", "type": "string" },
            { "name": "column", "type": "string" }
          ],
          "outputs": [{ "name": "columns", "type": "any[]" }]
        }
      },
      {
        "id": "node-FirstText",
        "type": "ewoAc",
        "position": { "x": 1560, "y": 250 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "FirstText",
          "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }],
          "outputs": [{ "name": "row", "type": "any" }]
        }
      },
      {
        "id": "node-PackResult",
        "type": "ewoAc",
        "position": { "x": 1780, "y": 140 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "PackResult",
          "operation": "PackFieldsAC",
          "inputs": [
            { "name": "text", "type": "any" },
            { "name": "jointId", "type": "any" }
          ],
          "outputs": [{ "name": "packed", "type": "object" }]
        }
      },
      {
        "id": "node-GetFirstResult",
        "type": "ewoAc",
        "position": { "x": 2660, "y": 300 },
        "data": {
          "label": "GetFirstResult",
          "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }],
          "outputs": [{ "name": "row", "type": "any" }]
        }
      },
      {
        "id": "node-UnpackResult",
        "type": "ewoAc",
        "position": { "x": 2880, "y": 300 },
        "data": {
          "label": "UnpackResult",
          "operation": "UnpackResultAC",
          "inputs": [{ "name": "packed", "type": "object" }],
          "outputs": [
            { "name": "text", "type": "string" },
            { "name": "jointId", "type": "string" }
          ]
        }
      },
      {
        "id": "node-end",
        "type": "ewoEnd",
        "position": { "x": 3100, "y": 300 },
        "data": {
          "outputs": [
            { "name": "text", "type": "string" },
            { "name": "jointId", "type": "string" }
          ]
        }
      }
    ],
    "edges": [
      { "id": "e-start-search", "source": "node-start", "target": "node-SearchVarNames" },
      { "id": "e-search-zone", "source": "node-SearchVarNames", "target": "region-varNameZone", "sourceHandle": "output-lineIds", "targetHandle": "input-collection" },
      { "id": "e-zone-iter-getpar", "source": "region-varNameZone", "target": "node-GetParentId", "sourceHandle": "iter-out", "targetHandle": "input-lineId" },
      { "id": "e-getpar-firstpar", "source": "node-GetParentId", "target": "node-FirstParent", "sourceHandle": "output-columns", "targetHandle": "input-rows" },
      { "id": "e-firstpar-searchanch", "source": "node-FirstParent", "target": "node-SearchAnchor", "sourceHandle": "output-row", "targetHandle": "input-lineId" },
      { "id": "e-searchanch-firstanch", "source": "node-SearchAnchor", "target": "node-FirstAnchor", "sourceHandle": "output-lineIds", "targetHandle": "input-rows" },
      { "id": "e-firstanch-getdep", "source": "node-FirstAnchor", "target": "node-GetDepId", "sourceHandle": "output-row", "targetHandle": "input-lineId" },
      { "id": "e-firstanch-searchlabel", "source": "node-FirstAnchor", "target": "node-SearchLabel", "sourceHandle": "output-row", "targetHandle": "input-parentId" },
      { "id": "e-getdep-firstjoint", "source": "node-GetDepId", "target": "node-FirstJointId", "sourceHandle": "output-columns", "targetHandle": "input-rows" },
      { "id": "e-firstjoint-pack", "source": "node-FirstJointId", "target": "node-PackResult", "sourceHandle": "output-row", "targetHandle": "input-jointId" },
      { "id": "e-searchlabel-firstlabel", "source": "node-SearchLabel", "target": "node-FirstLabelLine", "sourceHandle": "output-lineIds", "targetHandle": "input-rows" },
      { "id": "e-firstlabel-getlabelval", "source": "node-FirstLabelLine", "target": "node-GetLabelValue", "sourceHandle": "output-row", "targetHandle": "input-lineId" },
      { "id": "e-getlabelval-firsttext", "source": "node-GetLabelValue", "target": "node-FirstText", "sourceHandle": "output-columns", "targetHandle": "input-rows" },
      { "id": "e-firsttext-pack", "source": "node-FirstText", "target": "node-PackResult", "sourceHandle": "output-row", "targetHandle": "input-text" },
      { "id": "e-pack-collect", "source": "node-PackResult", "target": "region-varNameZone", "sourceHandle": "output-packed", "targetHandle": "collect-in" },
      { "id": "e-zone-getfirst", "source": "region-varNameZone", "target": "node-GetFirstResult", "sourceHandle": "output-results", "targetHandle": "input-rows" },
      { "id": "e-getfirst-unpack", "source": "node-GetFirstResult", "target": "node-UnpackResult", "sourceHandle": "output-row", "targetHandle": "input-packed" },
      { "id": "e-unpack-end", "source": "node-UnpackResult", "target": "node-end" }
    ]
  }
}
