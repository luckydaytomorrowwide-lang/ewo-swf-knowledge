{
  "id": "AddCopyBlockWF",
  "version": "1.0.0",
  "name": "AddCopyBlockWF",
  "description": "マスターブロックをコピーして追加する。バックエンドのAddCopyBlockWF.phpへ委譲。",
  "inputs": {
    "targetTableId": { "schema": "string" },
    "sourceTableId": { "schema": "string" },
    "sourceLineId": { "schema": "string" },
    "parentLineId": { "schema": "string" },
    "depth": { "schema": "number" }
  },
  "wfDef": {
    "nodes": [
      {
        "id": "Execute",
        "operation": "AddCopyBlockWF",
        "deps": {
          "targetTableId": { "sourceAcId": "$input", "sourcePort": "targetTableId" },
          "sourceTableId": { "sourceAcId": "$input", "sourcePort": "sourceTableId" },
          "sourceLineId": { "sourceAcId": "$input", "sourcePort": "sourceLineId" },
          "parentLineId": { "sourceAcId": "$input", "sourcePort": "parentLineId" },
          "depth": { "sourceAcId": "$input", "sourcePort": "depth" }
        },
        "outputs": { "rootLineId": {} },
        "wfCall": { "callee": "AddCopyBlockWF", "boundary": true }
      }
    ],
    "outputs": {
      "rootLineId": "Execute.rootLineId"
    }
  },
  "wiring": {
    "version": 1,
    "routes": [
      {
        "id": "R-Execute",
        "when": { "type": "Execute.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "wf.completed", "wfid": "AddCopyBlockWF", "map": "outputRef->payloadRef" }
        ]
      }
    ]
  },
  "layout": {
    "viewport": { "x": 0, "y": 0, "zoom": 0.85 },
    "nodes": [
      {
        "id": "node-start", "type": "ewoStart", "position": { "x": 50, "y": 150 },
        "data": { "inputs": [{ "name": "targetTableId", "type": "string" }, { "name": "sourceTableId", "type": "string" }, { "name": "sourceLineId", "type": "string" }, { "name": "parentLineId", "type": "string" }, { "name": "depth", "type": "number" }] }
      },
      {
        "id": "node-Execute", "type": "ewoWfCall", "position": { "x": 350, "y": 150 },
        "data": { "label": "Execute", "operation": "AddCopyBlockWF", "inputs": [{ "name": "targetTableId", "type": "string" }, { "name": "sourceTableId", "type": "string" }, { "name": "sourceLineId", "type": "string" }, { "name": "parentLineId", "type": "string" }, { "name": "depth", "type": "number" }], "outputs": [{ "name": "rootLineId", "type": "string" }], "wfCall": { "callee": "AddCopyBlockWF", "boundary": true } }
      },
      {
        "id": "node-end", "type": "ewoEnd", "position": { "x": 650, "y": 150 },
        "data": { "outputs": [{ "name": "rootLineId", "type": "string" }] }
      }
    ],
    "edges": [
      { "id": "e-start-exec", "source": "node-start", "target": "node-Execute" },
      { "id": "e-exec-end", "source": "node-Execute", "target": "node-end", "sourceHandle": "output-rootLineId", "targetHandle": "input-rootLineId" }
    ]
  }
}
