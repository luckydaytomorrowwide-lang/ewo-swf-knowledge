{
  "id": "BuildLayoutSnackingWF",
  "version": "1.0.0",
  "name": "BuildLayoutSnackingWF",
  "description": "гВєгГКгГГгВ≠гГ≥гВ∞гГђгВ§гВҐгВ¶гГИжІЛзѓЙгАВжЇЦеВЩ(RetrieveTableAC√Ч2вЖТPushRecordsAC√Ч2)вЖТrootгГЦгГ≠гГГгВѓгВ≠гГЉдљЬжИРвЖТsnackingConfigеПЦеЊЧвЖТForEach[nodeIds√Чconfigs: SearchNodeACвЖТBuildLayoutStructOldWFвЖТAddFormDataStoreACвЖТBlockKeyWFвЖТKeyMapвЖТReplaceKey]вЖТscheduleжЭ°дїґеИЖе≤РвЖТBuildLayoutActionWFвЖТгГЬгВњгГ≥ConfigвЖТForEach[BuildLayoutButtonWF]вЖТPaddingLayoutBlockACгАВ",
  "inputs": {
    "nodeIds": { "schema": "string[]" },
    "configId": { "schema": "string" },
    "snackingConfig": { "schema": "any[]" },
    "buttonConfig": { "schema": "any[]" },
    "keyMapConfig": { "schema": "object" },
    "ymd": { "schema": "string" },
    "mode": { "schema": "string" },
    "containerId": { "schema": "string" },
    "timestamp": { "schema": "any" },
    "traceContainerIds": { "schema": "string[]" },
    "traceFlowIds": { "schema": "string[]" }
  },
  "wfDef": {
    "nodes": [
      {
        "id": "RetrieveStructTable",
        "operation": "RetrieveTableAC",
        "deps": {
          "tableId": { "literal": "button_structs" }
        },
        "outputs": { "rows": {} }
      },
      {
        "id": "PushStructTable",
        "operation": "PushRecordsAC",
        "deps": {
          "tableId": { "literal": "button_structs" },
          "afterRows": { "sourceAcId": "RetrieveStructTable", "sourcePort": "rows" }
        },
        "outputs": {}
      },
      {
        "id": "RetrieveDataTable",
        "operation": "RetrieveTableAC",
        "deps": {
          "tableId": { "literal": "button_data" }
        },
        "outputs": { "rows": {} }
      },
      {
        "id": "PushDataTable",
        "operation": "PushRecordsAC",
        "deps": {
          "tableId": { "literal": "button_data" },
          "afterRows": { "sourceAcId": "RetrieveDataTable", "sourcePort": "rows" }
        },
        "outputs": {}
      },
      {
        "id": "BuildRootKey",
        "operation": "BuildLayoutBlockKeyWF",
        "deps": {
          "parentKey": { "literal": null },
          "blockKey": { "literal": "root" }
        },
        "outputs": { "blockKey": {} },
        "wfCall": { "callee": "BuildLayoutBlockKeyWF", "boundary": true }
      },
      {
        "id": "BuildRootRow",
        "operation": "BuildLayoutBlockRowAC",
        "deps": {
          "blockKey": { "sourceAcId": "BuildRootKey", "sourcePort": "blockKey" },
          "instViewType": { "literal": "card" },
          "instEditType": { "literal": "card" },
          "tplViewType": { "literal": "card" },
          "tplEditType": { "literal": "card" }
        },
        "outputs": { "layoutRow": {} }
      },
      {
        "id": "GetSnackingConfig",
        "operation": "GetLayoutSnackingConfigAC",
        "guard": "$input.snackingConfig == null",
        "deps": {
          "configId": { "sourceAcId": "$input", "sourcePort": "configId" }
        },
        "outputs": { "configs": {} }
      },
      {
        "id": "ResolveSnackingConfig",
        "operation": "CoalesceAC",
        "deps": {
          "primary": { "sourceAcId": "$input", "sourcePort": "snackingConfig" },
          "fallback": { "sourceAcId": "GetSnackingConfig", "sourcePort": "configs" }
        },
        "outputs": { "value": {} }
      },
      {
        "id": "SearchNode",
        "operation": "SearchNodeAC",
        "deps": {
          "searchType": { "sourceAcId": "$zoneInput", "sourcePort": "configItem.searchType" },
          "nodeId": { "sourceAcId": "$zoneInput", "sourcePort": "nodeItem" },
          "edgeType": { "sourceAcId": "$zoneInput", "sourcePort": "configItem.edgeType" },
          "nodeLabel": { "sourceAcId": "$zoneInput", "sourcePort": "configItem.nodeLabel" }
        },
        "outputs": { "nodeIds": {} }
      },
      {
        "id": "BuildStructOld",
        "operation": "BuildLayoutStructOldWF",
        "deps": {
          "rows": { "sourceAcId": "SearchNode", "sourcePort": "nodeIds" },
          "anchorKey": { "sourceAcId": "$zoneInput", "sourcePort": "configItem.anchorKey" },
          "lineKey": { "sourceAcId": "$zoneInput", "sourcePort": "configItem.lineKey" },
          "column": { "sourceAcId": "$zoneInput", "sourcePort": "configItem.column" }
        },
        "outputs": { "layoutRows": {} },
        "wfCall": { "callee": "BuildLayoutStructOldWF", "boundary": true }
      },
      {
        "id": "AddFormDataStore",
        "operation": "AddFormDataStoreByOutputJsonAC",
        "deps": {
          "layoutRows": { "sourceAcId": "BuildStructOld", "sourcePort": "layoutRows" }
        },
        "outputs": {}
      },
      {
        "id": "BuildAnchorKey",
        "operation": "BuildLayoutBlockKeyWF",
        "deps": {
          "parentKey": { "sourceAcId": "BuildRootKey", "sourcePort": "blockKey" },
          "blockKey": { "sourceAcId": "$zoneInput", "sourcePort": "nodeItem" }
        },
        "outputs": { "blockKey": {} },
        "wfCall": { "callee": "BuildLayoutBlockKeyWF", "boundary": true }
      },
      {
        "id": "GetKeyMapConfig",
        "operation": "GetLayoutKeyMapConfigAC",
        "guard": "$input.keyMapConfig == null",
        "deps": {
          "no": { "sourceAcId": "$zoneInput", "sourcePort": "configItem.no" },
          "configId": { "sourceAcId": "$input", "sourcePort": "configId" }
        },
        "outputs": { "key": {} }
      },
      {
        "id": "ResolveKeyMap",
        "operation": "ResolveKeyMapAC",
        "deps": {
          "keyMapConfig": { "sourceAcId": "$input", "sourcePort": "keyMapConfig" },
          "no": { "sourceAcId": "$zoneInput", "sourcePort": "configItem.no" },
          "fallbackKey": { "sourceAcId": "GetKeyMapConfig", "sourcePort": "key" }
        },
        "outputs": { "replaceKey": {} }
      },
      {
        "id": "ReplaceKey",
        "operation": "ReplaceLayoutKeyAC",
        "guard": "ResolveKeyMap.replaceKey != null",
        "deps": {
          "layoutRows": { "sourceAcId": "BuildStructOld", "sourcePort": "layoutRows" },
          "prefixKey": { "sourceAcId": "BuildAnchorKey", "sourcePort": "blockKey" },
          "replaceKey": { "sourceAcId": "ResolveKeyMap", "sourcePort": "replaceKey" }
        },
        "outputs": { "layoutRows": {} }
      },
      {
        "id": "CollectSnackingRows",
        "operation": "FlattenLayoutRowsAC",
        "deps": {
          "nestedRows": { "sourceAcId": "$zone:nodeZone", "sourcePort": "allNodeResults" }
        },
        "outputs": { "layoutRows": {} }
      },
      {
        "id": "MergeRootAndSnacking",
        "operation": "MergeLayoutRowsAC",
        "deps": {
          "rootRow": { "sourceAcId": "BuildRootRow", "sourcePort": "layoutRow" },
          "snackingRows": { "sourceAcId": "CollectSnackingRows", "sourcePort": "layoutRows" }
        },
        "outputs": { "layoutRows": {} }
      },
      {
        "id": "ConvertCalendar",
        "operation": "ConvertScheduleToCalendarEventAC",
        "guard": "$input.configId == \"schedule\"",
        "deps": {
          "layoutRows": { "sourceAcId": "MergeRootAndSnacking", "sourcePort": "layoutRows" }
        },
        "outputs": { "layoutRows": {} }
      },
      {
        "id": "BuildCalendarJson",
        "operation": "BuildLayoutCalendarJsonAC",
        "guard": "$input.configId == \"schedule\"",
        "deps": {
          "ymd": { "sourceAcId": "$input", "sourcePort": "ymd" },
          "mode": { "sourceAcId": "$input", "sourcePort": "mode" }
        },
        "outputs": { "layoutRows": {} }
      },
      {
        "id": "MergeAfterSchedule",
        "operation": "MergeLayoutRowsAC",
        "deps": {
          "baseRows": { "sourceAcId": "MergeRootAndSnacking", "sourcePort": "layoutRows" },
          "calendarConvertedRows": { "sourceAcId": "ConvertCalendar", "sourcePort": "layoutRows" },
          "calendarJsonRows": { "sourceAcId": "BuildCalendarJson", "sourcePort": "layoutRows" }
        },
        "outputs": { "layoutRows": {} }
      },
      {
        "id": "BuildAction",
        "operation": "BuildLayoutActionWF",
        "deps": {
          "configId": { "sourceAcId": "$input", "sourcePort": "configId" },
          "layoutRows": { "sourceAcId": "MergeAfterSchedule", "sourcePort": "layoutRows" },
          "containerId": { "sourceAcId": "$input", "sourcePort": "containerId" },
          "timestamp": { "sourceAcId": "$input", "sourcePort": "timestamp" },
          "traceContainerIds": { "sourceAcId": "$input", "sourcePort": "traceContainerIds" },
          "traceFlowIds": { "sourceAcId": "$input", "sourcePort": "traceFlowIds" }
        },
        "outputs": { "layoutRows": {} },
        "wfCall": { "callee": "BuildLayoutActionWF", "boundary": true }
      },
      {
        "id": "MergeAfterAction",
        "operation": "MergeLayoutRowsAC",
        "deps": {
          "baseRows": { "sourceAcId": "MergeAfterSchedule", "sourcePort": "layoutRows" },
          "actionRows": { "sourceAcId": "BuildAction", "sourcePort": "layoutRows" }
        },
        "outputs": { "layoutRows": {} }
      },
      {
        "id": "GetButtonConfig",
        "operation": "GetLayoutButtonConfigAC",
        "guard": "$input.buttonConfig == null",
        "deps": {
          "configId": { "sourceAcId": "$input", "sourcePort": "configId" }
        },
        "outputs": { "configs": {} }
      },
      {
        "id": "ResolveButtonConfig",
        "operation": "CoalesceAC",
        "deps": {
          "primary": { "sourceAcId": "$input", "sourcePort": "buttonConfig" },
          "fallback": { "sourceAcId": "GetButtonConfig", "sourcePort": "configs" }
        },
        "outputs": { "value": {} }
      },
      {
        "id": "BuildButton",
        "operation": "BuildLayoutButtonWF",
        "deps": {
          "layoutRows": { "sourceAcId": "MergeAfterAction", "sourcePort": "layoutRows" },
          "isRoot": { "sourceAcId": "$zoneInput", "sourcePort": "buttonItem.isRoot" },
          "viewType": { "sourceAcId": "$zoneInput", "sourcePort": "buttonItem.viewType" },
          "editType": { "sourceAcId": "$zoneInput", "sourcePort": "buttonItem.editType" },
          "tableId": { "literal": "button_structs" },
          "nCat": { "literal": "anchor" },
          "key": { "sourceAcId": "$zoneInput", "sourcePort": "buttonItem.buttonRootKey" }
        },
        "outputs": { "layoutRows": {} },
        "wfCall": { "callee": "BuildLayoutButtonWF", "boundary": true }
      },
      {
        "id": "CollectButtonRows",
        "operation": "FlattenLayoutRowsAC",
        "deps": {
          "nestedRows": { "sourceAcId": "$zone:buttonZone", "sourcePort": "allButtonResults" }
        },
        "outputs": { "layoutRows": {} }
      },
      {
        "id": "MergeAfterButton",
        "operation": "MergeLayoutRowsAC",
        "deps": {
          "baseRows": { "sourceAcId": "MergeAfterAction", "sourcePort": "layoutRows" },
          "buttonRows": { "sourceAcId": "CollectButtonRows", "sourcePort": "layoutRows" }
        },
        "outputs": { "layoutRows": {} }
      },
      {
        "id": "PaddingBlock",
        "operation": "PaddingLayoutBlockAC",
        "deps": {
          "layoutRows": { "sourceAcId": "MergeAfterButton", "sourcePort": "layoutRows" }
        },
        "outputs": { "layoutRows": {} }
      },
      {
        "id": "FinalMerge",
        "operation": "MergeLayoutRowsAC",
        "deps": {
          "baseRows": { "sourceAcId": "MergeAfterButton", "sourcePort": "layoutRows" },
          "paddingRows": { "sourceAcId": "PaddingBlock", "sourcePort": "layoutRows" }
        },
        "outputs": { "layoutRows": {} }
      }
    ],
    "forEachZones": [
      {
        "id": "nodeZone",
        "collectionSource": {
          "sourceAcId": "$input",
          "sourcePort": "nodeIds"
        },
        "iterationParam": "nodeItem",
        "nodes": [],
        "childZones": [
          {
            "id": "configZone",
            "collectionSource": {
              "sourceAcId": "ResolveSnackingConfig",
              "sourcePort": "value"
            },
            "iterationParam": "configItem",
            "nodes": ["SearchNode", "BuildStructOld", "AddFormDataStore", "BuildAnchorKey", "GetKeyMapConfig", "ResolveKeyMap", "ReplaceKey"],
            "outputNodeId": "ReplaceKey",
            "outputPort": "layoutRows",
            "outputCollection": "allConfigResults"
          }
        ],
        "outputNodeId": "configZone",
        "outputPort": "allConfigResults",
        "outputCollection": "allNodeResults"
      },
      {
        "id": "buttonZone",
        "collectionSource": {
          "sourceAcId": "ResolveButtonConfig",
          "sourcePort": "value"
        },
        "iterationParam": "buttonItem",
        "nodes": ["BuildButton"],
        "outputNodeId": "BuildButton",
        "outputPort": "layoutRows",
        "outputCollection": "allButtonResults"
      }
    ],
    "outputs": {
      "layoutRows": "FinalMerge.layoutRows"
    }
  },
  "wiring": {
    "version": 1,
    "routes": [
      { "id": "R-RetrieveStructTable", "when": { "type": "RetrieveStructTable.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "PushStructTable.afterRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-PushStructTable", "when": { "type": "PushStructTable.done" }, "correlate": { "by": ["correlationid"] }, "emit": [] },
      { "id": "R-RetrieveDataTable", "when": { "type": "RetrieveDataTable.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "PushDataTable.afterRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-PushDataTable", "when": { "type": "PushDataTable.done" }, "correlate": { "by": ["correlationid"] }, "emit": [] },
      { "id": "R-BuildRootKey", "when": { "type": "BuildRootKey.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "BuildRootRow.blockKey", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }, { "type": "BuildAnchorKey.parentKey", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-BuildRootRow", "when": { "type": "BuildRootRow.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "MergeRootAndSnacking.rootRow", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-GetSnackingConfig", "when": { "type": "GetSnackingConfig.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "ResolveSnackingConfig.fallback", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-ResolveSnackingConfig", "when": { "type": "ResolveSnackingConfig.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "$zone:configZone.input", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-SearchNode", "when": { "type": "SearchNode.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "BuildStructOld.rows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-BuildStructOld", "when": { "type": "BuildStructOld.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "AddFormDataStore.layoutRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }, { "type": "ReplaceKey.layoutRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-AddFormDataStore", "when": { "type": "AddFormDataStore.done" }, "correlate": { "by": ["correlationid"] }, "emit": [] },
      { "id": "R-BuildAnchorKey", "when": { "type": "BuildAnchorKey.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "ReplaceKey.prefixKey", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-GetKeyMapConfig", "when": { "type": "GetKeyMapConfig.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "ResolveKeyMap.fallbackKey", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-ResolveKeyMap", "when": { "type": "ResolveKeyMap.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "ReplaceKey.replaceKey", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-ReplaceKey", "when": { "type": "ReplaceKey.done" }, "correlate": { "by": ["correlationid"] }, "emit": [] },
      { "id": "R-$zone:configZone", "when": { "type": "$zone:configZone.done" }, "correlate": { "by": ["correlationid"] }, "emit": [] },
      { "id": "R-$zone:nodeZone", "when": { "type": "$zone:nodeZone.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "CollectSnackingRows.nestedRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-CollectSnackingRows", "when": { "type": "CollectSnackingRows.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "MergeRootAndSnacking.snackingRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-MergeRootAndSnacking", "when": { "type": "MergeRootAndSnacking.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "ConvertCalendar.layoutRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }, { "type": "MergeAfterSchedule.baseRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-ConvertCalendar", "when": { "type": "ConvertCalendar.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "MergeAfterSchedule.calendarConvertedRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-BuildCalendarJson", "when": { "type": "BuildCalendarJson.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "MergeAfterSchedule.calendarJsonRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-MergeAfterSchedule", "when": { "type": "MergeAfterSchedule.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "BuildAction.layoutRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }, { "type": "MergeAfterAction.baseRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-BuildAction", "when": { "type": "BuildAction.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "MergeAfterAction.actionRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-MergeAfterAction", "when": { "type": "MergeAfterAction.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "BuildButton.layoutRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }, { "type": "MergeAfterButton.baseRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-GetButtonConfig", "when": { "type": "GetButtonConfig.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "ResolveButtonConfig.fallback", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-ResolveButtonConfig", "when": { "type": "ResolveButtonConfig.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "$zone:buttonZone.input", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-BuildButton", "when": { "type": "BuildButton.done" }, "correlate": { "by": ["correlationid"] }, "emit": [] },
      { "id": "R-$zone:buttonZone", "when": { "type": "$zone:buttonZone.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "CollectButtonRows.nestedRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-CollectButtonRows", "when": { "type": "CollectButtonRows.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "MergeAfterButton.buttonRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-MergeAfterButton", "when": { "type": "MergeAfterButton.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "PaddingBlock.layoutRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }, { "type": "FinalMerge.baseRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-PaddingBlock", "when": { "type": "PaddingBlock.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "FinalMerge.paddingRows", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] },
      { "id": "R-FinalMerge", "when": { "type": "FinalMerge.done" }, "correlate": { "by": ["correlationid"] }, "emit": [{ "type": "wf.completed", "wfid": "BuildLayoutSnackingWF", "map": "outputRef->payloadRef" }] }
    ]
  },
  "layout": {
    "viewport": { "x": 0, "y": 0, "zoom": 0.3 },
    "nodes": [
      { "id": "node-start", "type": "ewoStart", "position": { "x": 50, "y": 500 }, "data": { "inputs": [{ "name": "nodeIds", "type": "string[]" }, { "name": "configId", "type": "string" }, { "name": "snackingConfig", "type": "any[]" }, { "name": "buttonConfig", "type": "any[]" }, { "name": "keyMapConfig", "type": "object" }, { "name": "ymd", "type": "string" }, { "name": "mode", "type": "string" }] } },
      { "id": "node-RetrieveStructTable", "type": "ewoAc", "position": { "x": 300, "y": 80 }, "data": { "label": "RetrieveStructTable", "operation": "RetrieveTableAC" } },
      { "id": "node-PushStructTable", "type": "ewoAc", "position": { "x": 560, "y": 80 }, "data": { "label": "PushStructTable", "operation": "PushRecordsAC" } },
      { "id": "node-RetrieveDataTable", "type": "ewoAc", "position": { "x": 300, "y": 200 }, "data": { "label": "RetrieveDataTable", "operation": "RetrieveTableAC" } },
      { "id": "node-PushDataTable", "type": "ewoAc", "position": { "x": 560, "y": 200 }, "data": { "label": "PushDataTable", "operation": "PushRecordsAC" } },
      { "id": "node-BuildRootKey", "type": "ewoWfCall", "position": { "x": 300, "y": 380 }, "data": { "label": "BuildRootKey", "operation": "BuildLayoutBlockKeyWF", "wfCall": { "callee": "BuildLayoutBlockKeyWF", "boundary": true } } },
      { "id": "node-BuildRootRow", "type": "ewoAc", "position": { "x": 560, "y": 380 }, "data": { "label": "BuildRootRow", "operation": "BuildLayoutBlockRowAC" } },
      { "id": "node-GetSnackingConfig", "type": "ewoAc", "position": { "x": 300, "y": 520 }, "data": { "label": "GetSnackingConfig", "operation": "GetLayoutSnackingConfigAC", "guard": "$input.snackingConfig == null" } },
      { "id": "node-ResolveSnackingConfig", "type": "ewoAc", "position": { "x": 560, "y": 520 }, "data": { "label": "ResolveSnackingConfig", "operation": "CoalesceAC" } },
      { "id": "region-nodeZone", "type": "ewoForEachRegion", "position": { "x": 840, "y": 350 }, "style": { "width": "1600px", "height": "500px" }, "data": { "label": "NodeZone (nodeIds iterate)", "zoneId": "nodeZone", "iterationParam": "nodeItem", "outputCollection": "allNodeResults" } },
