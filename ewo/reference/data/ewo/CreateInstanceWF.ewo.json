{
  "id": "CreateInstanceWF",
  "version": "1.0.0",
  "name": "CreateInstanceWF",
  "description": "インスタンスを作成する。バックエンドのCreateInstanceWF.phpへ委譲。",
  "inputs": {
    "nodeLabels": { "schema": "string" },
    "nodeId": { "schema": "string" }
  },
  "wfDef": {
    "nodes": [
      {
        "id": "Execute",
        "operation": "CreateInstanceWF",
        "deps": {
          "nodeLabels": { "sourceAcId": "$input", "sourcePort": "nodeLabels" },
          "nodeId": { "sourceAcId": "$input", "sourcePort": "nodeId" }
        },
        "outputs": { "nodeId": {}, "tableId": {}, "rootLineId": {} },
        "wfCall": { "callee": "CreateInstanceWF", "boundary": true }
      }
    ],
    "outputs": {
      "nodeId": "Execute.nodeId",
      "tableId": "Execute.tableId",
      "rootLineId": "Execute.rootLineId"
    }
  },
  "wiring": {
    "version": 1,
    "routes": [
      {
        "id": "R-Execute",
        "when": { "type": "Execute.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "wf.completed", "wfid": "CreateInstanceWF", "map": "outputRef->payloadRef" }
        ]
      }
    ]
  },
  "layout": {
    "viewport": { "x": 0, "y": 0, "zoom": 0.85 },
    "nodes": [
      {
        "id": "node-start", "type": "ewoStart", "position": { "x": 50, "y": 150 },
        "data": { "inputs": [{ "name": "nodeLabels", "type": "string" }, { "name": "nodeId", "type": "string" }] }
      },
      {
        "id": "node-Execute", "type": "ewoWfCall", "position": { "x": 350, "y": 150 },
        "data": { "label": "Execute", "operation": "CreateInstanceWF", "inputs": [{ "name": "nodeLabels", "type": "string" }, { "name": "nodeId", "type": "string" }], "outputs": [{ "name": "nodeId", "type": "string" }, { "name": "tableId", "type": "string" }, { "name": "rootLineId", "type": "string" }], "wfCall": { "callee": "CreateInstanceWF", "boundary": true } }
      },
      {
        "id": "node-end", "type": "ewoEnd", "position": { "x": 650, "y": 150 },
        "data": { "outputs": [{ "name": "nodeId", "type": "string" }, { "name": "tableId", "type": "string" }, { "name": "rootLineId", "type": "string" }] }
      }
    ],
    "edges": [
      { "id": "e-start-exec", "source": "node-start", "target": "node-Execute" },
      { "id": "e-exec-end", "source": "node-Execute", "target": "node-end" }
    ]
  }
}
