{
  "id": "GetCellWF",
  "version": "1.0.0",
  "name": "GetCellWF",
  "description": "VAR_NAMEでテーブル行を検索し、parent→anchor→field→columnの順でセル値を取得する。varNameUlidsをForEachでiterate。",
  "inputs": {
    "arg1": { "schema": "string" },
    "arg2": { "schema": "string" },
    "arg3": { "schema": "string" },
    "arg4": { "schema": "string" },
    "arg5": { "schema": "string" }
  },
  "wfDef": {
    "nodes": [
      {
        "id": "SearchVarNames",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "key": { "literal": "VAR_NAME" },
          "value": { "sourceAcId": "$input", "sourcePort": "arg2" }
        },
        "outputs": { "lineIds": {} }
      },

      {
        "id": "GetParentId",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "lineId": { "sourceAcId": "$zoneInput", "sourcePort": "varNameItem" },
          "column": { "literal": "parent_id" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstParent",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "GetParentId", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "SearchAnchor",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "lineId": { "sourceAcId": "FirstParent", "sourcePort": "row" },
          "nCat": { "literal": "anchor" },
          "uCat": { "sourceAcId": "$input", "sourcePort": "arg3" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "FirstAnchor",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "SearchAnchor", "sourcePort": "lineIds" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "SearchField",
        "operation": "SearchLineAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "parentId": { "sourceAcId": "FirstAnchor", "sourcePort": "row" },
          "key": { "sourceAcId": "$input", "sourcePort": "arg4" }
        },
        "outputs": { "lineIds": {} }
      },
      {
        "id": "FirstField",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "SearchField", "sourcePort": "lineIds" }
        },
        "outputs": { "row": {} }
      },
      {
        "id": "GetColValue",
        "operation": "RetrieveColumnAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "arg1" },
          "lineId": { "sourceAcId": "FirstField", "sourcePort": "row" },
          "column": { "sourceAcId": "$input", "sourcePort": "arg5" }
        },
        "outputs": { "columns": {} }
      },
      {
        "id": "FirstText",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "GetColValue", "sourcePort": "columns" }
        },
        "outputs": { "row": {} }
      },

      {
        "id": "GetFirstText",
        "operation": "FirstRowAC",
        "deps": {
          "rows": { "sourceAcId": "$zone:varNameZone", "sourcePort": "allTexts" }
        },
        "outputs": { "row": {} }
      }
    ],
    "forEachZones": [
      {
        "id": "varNameZone",
        "collectionSource": {
          "sourceAcId": "SearchVarNames",
          "sourcePort": "lineIds"
        },
        "iterationParam": "varNameItem",
        "nodes": [
          "GetParentId", "FirstParent", "SearchAnchor", "FirstAnchor",
          "SearchField", "FirstField", "GetColValue", "FirstText"
        ],
        "outputNodeId": "FirstText",
        "outputPort": "row",
        "outputCollection": "allTexts"
      }
    ],
    "outputs": {
      "text": "GetFirstText.row"
    }
  },
  "wiring": {
    "version": 1,
    "routes": [
      {
        "id": "R-SearchVarNames",
        "when": { "type": "SearchVarNames.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "$zone:varNameZone.input", "wfid": "GetCellWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-GetParentId",
        "when": { "type": "GetParentId.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstParent.rows", "wfid": "GetCellWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstParent",
        "when": { "type": "FirstParent.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "SearchAnchor.lineId", "wfid": "GetCellWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-SearchAnchor",
        "when": { "type": "SearchAnchor.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstAnchor.rows", "wfid": "GetCellWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstAnchor",
        "when": { "type": "FirstAnchor.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "SearchField.parentId", "wfid": "GetCellWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-SearchField",
        "when": { "type": "SearchField.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstField.rows", "wfid": "GetCellWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstField",
        "when": { "type": "FirstField.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "GetColValue.lineId", "wfid": "GetCellWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-GetColValue",
        "when": { "type": "GetColValue.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "FirstText.rows", "wfid": "GetCellWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-FirstText",
        "when": { "type": "FirstText.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": []
      },
      {
        "id": "R-$zone:varNameZone",
        "when": { "type": "$zone:varNameZone.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "GetFirstText.rows", "wfid": "GetCellWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-GetFirstText",
        "when": { "type": "GetFirstText.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "wf.completed", "wfid": "GetCellWF", "map": "outputRef->payloadRef" }
        ]
      }
    ]
  },
  "layout": {
    "viewport": { "x": 0, "y": 0, "zoom": 0.5 },
    "nodes": [
      {
        "id": "node-start",
        "type": "ewoStart",
        "position": { "x": 50, "y": 250 },
        "data": {
          "inputs": [
            { "name": "arg1", "type": "string" },
            { "name": "arg2", "type": "string" },
            { "name": "arg3", "type": "string" },
            { "name": "arg4", "type": "string" },
            { "name": "arg5", "type": "string" }
          ]
        }
      },
      {
        "id": "node-SearchVarNames",
        "type": "ewoAc",
        "position": { "x": 260, "y": 250 },
        "data": {
          "label": "SearchVarNames",
          "operation": "SearchLineAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "key", "type": "string" },
            { "name": "value", "type": "string" }
          ],
          "outputs": [{ "name": "lineIds", "type": "string[]" }]
        }
      },
      {
        "id": "region-varNameZone",
        "type": "ewoForEachRegion",
        "position": { "x": 500, "y": 40 },
        "style": { "width": "1800px", "height": "350px" },
        "data": {
          "label": "VarNameZone (varNameUlids iterate)",
          "zoneId": "varNameZone",
          "iterationParam": "varNameItem",
          "outputCollection": "allTexts"
        }
      },
      {
        "id": "node-GetParentId",
        "type": "ewoAc",
        "position": { "x": 40, "y": 100 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "GetParentId",
          "operation": "RetrieveColumnAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "lineId", "type": "string" },
            { "name": "column", "type": "string" }
          ],
          "outputs": [{ "name": "columns", "type": "any[]" }]
        }
      },
      {
        "id": "node-FirstParent",
        "type": "ewoAc",
        "position": { "x": 240, "y": 100 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "FirstParent",
          "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }],
          "outputs": [{ "name": "row", "type": "any" }]
        }
      },
      {
        "id": "node-SearchAnchor",
        "type": "ewoAc",
        "position": { "x": 440, "y": 100 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "SearchAnchor",
          "operation": "SearchLineAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "lineId", "type": "string" },
            { "name": "nCat", "type": "string" },
            { "name": "uCat", "type": "string" }
          ],
          "outputs": [{ "name": "lineIds", "type": "string[]" }]
        }
      },
      {
        "id": "node-FirstAnchor",
        "type": "ewoAc",
        "position": { "x": 660, "y": 100 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "FirstAnchor",
          "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }],
          "outputs": [{ "name": "row", "type": "any" }]
        }
      },
      {
        "id": "node-SearchField",
        "type": "ewoAc",
        "position": { "x": 880, "y": 100 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "SearchField",
          "operation": "SearchLineAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "parentId", "type": "string" },
            { "name": "key", "type": "string" }
          ],
          "outputs": [{ "name": "lineIds", "type": "string[]" }]
        }
      },
      {
        "id": "node-FirstField",
        "type": "ewoAc",
        "position": { "x": 1080, "y": 100 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "FirstField",
          "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }],
          "outputs": [{ "name": "row", "type": "any" }]
        }
      },
      {
        "id": "node-GetColValue",
        "type": "ewoAc",
        "position": { "x": 1280, "y": 100 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "GetColValue",
          "operation": "RetrieveColumnAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "lineId", "type": "string" },
            { "name": "column", "type": "string" }
          ],
          "outputs": [{ "name": "columns", "type": "any[]" }]
        }
      },
      {
        "id": "node-FirstText",
        "type": "ewoAc",
        "position": { "x": 1480, "y": 100 },
        "parentNode": "region-varNameZone",
        "extent": "parent",
        "data": {
          "label": "FirstText",
          "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }],
          "outputs": [{ "name": "row", "type": "any" }]
        }
      },
      {
        "id": "node-GetFirstText",
        "type": "ewoAc",
        "position": { "x": 2360, "y": 250 },
        "data": {
          "label": "GetFirstText",
          "operation": "FirstRowAC",
          "inputs": [{ "name": "rows", "type": "any[]" }],
          "outputs": [{ "name": "row", "type": "any" }]
        }
      },
      {
        "id": "node-end",
        "type": "ewoEnd",
        "position": { "x": 2580, "y": 250 },
        "data": {
          "outputs": [{ "name": "text", "type": "string" }]
        }
      }
    ],
    "edges": [
      { "id": "e-start-search", "source": "node-start", "target": "node-SearchVarNames" },
      { "id": "e-search-zone", "source": "node-SearchVarNames", "target": "region-varNameZone", "sourceHandle": "output-lineIds", "targetHandle": "input-collection" },
      { "id": "e-zone-iter-getpar", "source": "region-varNameZone", "target": "node-GetParentId", "sourceHandle": "iter-out", "targetHandle": "input-lineId" },
      { "id": "e-getpar-firstpar", "source": "node-GetParentId", "target": "node-FirstParent", "sourceHandle": "output-columns", "targetHandle": "input-rows" },
      { "id": "e-firstpar-searchanch", "source": "node-FirstParent", "target": "node-SearchAnchor", "sourceHandle": "output-row", "targetHandle": "input-lineId" },
      { "id": "e-searchanch-firstanch", "source": "node-SearchAnchor", "target": "node-FirstAnchor", "sourceHandle": "output-lineIds", "targetHandle": "input-rows" },
      { "id": "e-firstanch-searchfld", "source": "node-FirstAnchor", "target": "node-SearchField", "sourceHandle": "output-row", "targetHandle": "input-parentId" },
      { "id": "e-searchfld-firstfld", "source": "node-SearchField", "target": "node-FirstField", "sourceHandle": "output-lineIds", "targetHandle": "input-rows" },
      { "id": "e-firstfld-getcolval", "source": "node-FirstField", "target": "node-GetColValue", "sourceHandle": "output-row", "targetHandle": "input-lineId" },
      { "id": "e-getcolval-firsttext", "source": "node-GetColValue", "target": "node-FirstText", "sourceHandle": "output-columns", "targetHandle": "input-rows" },
      { "id": "e-firsttext-collect", "source": "node-FirstText", "target": "region-varNameZone", "sourceHandle": "output-row", "targetHandle": "collect-in" },
      { "id": "e-zone-getfirst", "source": "region-varNameZone", "target": "node-GetFirstText", "sourceHandle": "output-results", "targetHandle": "input-rows" },
      { "id": "e-getfirst-end", "source": "node-GetFirstText", "target": "node-end", "sourceHandle": "output-row", "targetHandle": "input-text" }
    ]
  }
}
