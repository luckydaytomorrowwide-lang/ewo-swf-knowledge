        "position": { "x": 300, "y": 340 },
        "data": {
          "label": "ConvertTableName",
          "operation": "ConvertStructToDataTableNameAC",
          "inputs": [{ "name": "tableId", "type": "string" }],
          "outputs": [{ "name": "tableId", "type": "string" }]
        }
      },
      {
        "id": "node-DeployStruct",
        "type": "ewoWfCall",
        "position": { "x": 300, "y": 100 },
        "data": {
          "label": "DeployStruct",
          "operation": "DeployBlockTemporaryWF",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "lineId", "type": "string" },
            { "name": "depth", "type": "number" },
            { "name": "type", "type": "string" }
          ],
          "outputs": [{ "name": "tempTableId", "type": "string" }],
          "wfCall": { "callee": "DeployBlockTemporaryWF", "boundary": true }
        }
      },
      {
        "id": "node-DeployData",
        "type": "ewoWfCall",
        "position": { "x": 600, "y": 340 },
        "data": {
          "label": "DeployData",
          "operation": "DeployBlockTemporaryWF",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "lineId", "type": "string" },
            { "name": "depth", "type": "number" },
            { "name": "type", "type": "string" }
          ],
          "outputs": [{ "name": "tempTableId", "type": "string" }],
          "wfCall": { "callee": "DeployBlockTemporaryWF", "boundary": true }
        }
      },
      {
        "id": "node-MergeTable",
        "type": "ewoAc",
        "position": { "x": 900, "y": 220 },
        "data": {
          "label": "MergeTable",
          "operation": "MergeTableAC",
          "inputs": [
            { "name": "structTableId", "type": "string" },
            { "name": "dataTableId", "type": "string" }
          ],
          "outputs": [{ "name": "rows", "type": "any[]" }]
        }
      },
      {
        "id": "node-BuildTempId",
        "type": "ewoAc",
        "position": { "x": 900, "y": 80 },
        "data": {
          "label": "BuildTempId",
          "operation": "BuildTemporaryTableIdAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "ulid", "type": "string" }
          ],
          "outputs": [{ "name": "tempTableId", "type": "string" }]
        }
      },
      {
        "id": "node-PushRecords",
        "type": "ewoAc",
        "position": { "x": 1180, "y": 220 },
        "data": {
          "label": "PushRecords",
          "operation": "PushRecordsAC",
          "inputs": [
            { "name": "tableId", "type": "string" },
            { "name": "afterRows", "type": "any[]" }
          ],
          "outputs": []
        }
      },
      {
        "id": "node-end",
        "type": "ewoEnd",
        "position": { "x": 1450, "y": 220 },
        "data": {
          "outputs": [{ "name": "tempTableId", "type": "string" }]
        }
      }
    ],
    "edges": [
      { "id": "e-start-convert", "source": "node-start", "target": "node-ConvertTableName", "sourceHandle": "output-tableId", "targetHandle": "input-tableId" },
      { "id": "e-start-struct-tableId", "source": "node-start", "target": "node-DeployStruct", "sourceHandle": "output-tableId", "targetHandle": "input-tableId" },
      { "id": "e-start-struct-lineId", "source": "node-start", "target": "node-DeployStruct", "sourceHandle": "output-lineId", "targetHandle": "input-lineId" },
      { "id": "e-convert-data", "source": "node-ConvertTableName", "target": "node-DeployData", "sourceHandle": "output-tableId", "targetHandle": "input-tableId" },
      { "id": "e-start-data-lineId", "source": "node-start", "target": "node-DeployData", "sourceHandle": "output-lineId", "targetHandle": "input-lineId" },
      { "id": "e-struct-merge", "source": "node-DeployStruct", "target": "node-MergeTable", "sourceHandle": "output-tempTableId", "targetHandle": "input-structTableId" },
      { "id": "e-data-merge", "source": "node-DeployData", "target": "node-MergeTable", "sourceHandle": "output-tempTableId", "targetHandle": "input-dataTableId" },
      { "id": "e-start-buildid-tableId", "source": "node-start", "target": "node-BuildTempId", "sourceHandle": "output-tableId", "targetHandle": "input-tableId" },
      { "id": "e-start-buildid-ulid", "source": "node-start", "target": "node-BuildTempId", "sourceHandle": "output-lineId", "targetHandle": "input-ulid" },
      { "id": "e-merge-push", "source": "node-MergeTable", "target": "node-PushRecords", "sourceHandle": "output-rows", "targetHandle": "input-afterRows" },
      { "id": "e-buildid-push", "source": "node-BuildTempId", "target": "node-PushRecords", "sourceHandle": "output-tempTableId", "targetHandle": "input-tableId" },
      { "id": "e-buildid-end", "source": "node-BuildTempId", "target": "node-end", "sourceHandle": "output-tempTableId", "targetHandle": "input-tempTableId" },
      { "id": "e-start-struct-depth", "source": "node-start", "target": "node-DeployStruct", "sourceHandle": "output-depth", "targetHandle": "input-depth" },
      { "id": "e-start-struct-type", "source": "node-start", "target": "node-DeployStruct", "sourceHandle": "output-type", "targetHandle": "input-type" },
      { "id": "e-start-data-depth", "source": "node-start", "target": "node-DeployData", "sourceHandle": "output-depth", "targetHandle": "input-depth" },
      { "id": "e-start-data-type", "source": "node-start", "target": "node-DeployData", "sourceHandle": "output-type", "targetHandle": "input-type" }
    ]
  }
