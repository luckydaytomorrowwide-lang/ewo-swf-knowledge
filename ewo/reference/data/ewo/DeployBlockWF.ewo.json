{
  "id": "DeployBlockWF",
  "version": "1.0.0",
  "name": "DeployBlockWF",
  "description": "Ńā¢ŃāŁŃāāŃé»ŃāćŃā╝Ńé┐ŃéÆÕ▒Ģķ¢ŗŃüŚŃā×Ńā╝ŃéĖŃüÖŃéŗŃĆéConvertStructToDataTableNameACŃü¦ŃāćŃā╝Ńé┐ŃāåŃā╝Ńā¢Ńā½ÕÉŹÕÅ¢ÕŠŚŌåÆDeployBlockTemporaryWFŃéÆµ¦ŗķĆĀŃā╗ŃāćŃā╝Ńé┐õĖĪµ¢╣Ńü¦õĖ”ÕłŚÕ«¤ĶĪīŌåÆMergeTableACŃü¦Ńā×Ńā╝ŃéĖŌåÆBuildTemporaryTableIdACŌåÆPushRecordsACŃü¦ŃāåŃā│ŃāØŃā®Ńā¬ŃāåŃā╝Ńā¢Ńā½ńÖ╗ķī▓ŃĆé",
  "inputs": {
    "tableId": { "schema": "string" },
    "lineId": { "schema": "string" },
    "depth": { "schema": "number" },
    "type": { "schema": "string" }
  },
  "wfDef": {
    "nodes": [
      {
        "id": "ConvertTableName",
        "operation": "ConvertStructToDataTableNameAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" }
        },
        "outputs": { "tableId": {} }
      },
      {
        "id": "DeployStruct",
        "operation": "DeployBlockTemporaryWF",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "lineId": { "sourceAcId": "$input", "sourcePort": "lineId" },
          "depth": { "sourceAcId": "$input", "sourcePort": "depth" },
          "type": { "sourceAcId": "$input", "sourcePort": "type" }
        },
        "outputs": { "tempTableId": {} },
        "wfCall": {
          "callee": "DeployBlockTemporaryWF",
          "boundary": true
        }
      },
      {
        "id": "DeployData",
        "operation": "DeployBlockTemporaryWF",
        "deps": {
          "tableId": { "sourceAcId": "ConvertTableName", "sourcePort": "tableId" },
          "lineId": { "sourceAcId": "$input", "sourcePort": "lineId" },
          "depth": { "sourceAcId": "$input", "sourcePort": "depth" },
          "type": { "sourceAcId": "$input", "sourcePort": "type" }
        },
        "outputs": { "tempTableId": {} },
        "wfCall": {
          "callee": "DeployBlockTemporaryWF",
          "boundary": true
        }
      },
      {
        "id": "MergeTable",
        "operation": "MergeTableAC",
        "deps": {
          "structTableId": { "sourceAcId": "DeployStruct", "sourcePort": "tempTableId" },
          "dataTableId": { "sourceAcId": "DeployData", "sourcePort": "tempTableId" }
        },
        "outputs": { "rows": {} }
      },
      {
        "id": "BuildTempId",
        "operation": "BuildTemporaryTableIdAC",
        "deps": {
          "tableId": { "sourceAcId": "$input", "sourcePort": "tableId" },
          "ulid": { "sourceAcId": "$input", "sourcePort": "lineId" }
        },
        "outputs": { "tempTableId": {} }
      },
      {
        "id": "PushRecords",
        "operation": "PushRecordsAC",
        "deps": {
          "tableId": { "sourceAcId": "BuildTempId", "sourcePort": "tempTableId" },
          "beforeRows": { "literal": [] },
          "afterRows": { "sourceAcId": "MergeTable", "sourcePort": "rows" }
        },
        "outputs": {}
      }
    ],
    "outputs": {
      "tempTableId": "BuildTempId.tempTableId"
    }
  },
  "wiring": {
    "version": 1,
    "routes": [
      {
        "id": "R-ConvertTableName",
        "when": { "type": "ConvertTableName.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "DeployData.tableId", "wfid": "DeployBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-DeployStruct",
        "when": { "type": "DeployStruct.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "MergeTable.structTableId", "wfid": "DeployBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-DeployData",
        "when": { "type": "DeployData.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "MergeTable.dataTableId", "wfid": "DeployBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-MergeTable",
        "when": { "type": "MergeTable.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "PushRecords.afterRows", "wfid": "DeployBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-BuildTempId",
        "when": { "type": "BuildTempId.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "PushRecords.tableId", "wfid": "DeployBlockWF", "map": "outputRef->payloadRef" }
        ]
      },
      {
        "id": "R-PushRecords",
        "when": { "type": "PushRecords.done" },
        "correlate": { "by": ["correlationid"] },
        "emit": [
          { "type": "wf.completed", "wfid": "DeployBlockWF", "map": "outputRef->payloadRef" }
        ]
      }
    ]
  },
  "layout": {
    "viewport": { "x": 0, "y": 0, "zoom": 0.75 },
    "nodes": [
      {
